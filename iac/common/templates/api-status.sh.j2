#!/bin/bash
# API Status Script
# Shows comprehensive status of Ploy API deployment via unified deployment system

set -e

PLOY_DIR="/home/ploy/ploy"

echo "=== Ploy API Status (Unified Deployment System) ==="

# Check if we're in the right directory
if [[ ! -d "$PLOY_DIR" ]]; then
    echo "Error: Ploy directory not found at $PLOY_DIR"
    exit 1
fi

cd "$PLOY_DIR"

# Current version and deployment method
echo "🔍 Current Deployment:"
CURRENT_VERSION=$(cat /opt/ploy/current-api-version 2>/dev/null || echo "unknown")
DEPLOYMENT_METHOD=$(cat /opt/ploy/deployment-method 2>/dev/null || echo "unknown")
echo "  Version: $CURRENT_VERSION"
echo "  Method: $DEPLOYMENT_METHOD"

# Git commit information
if git rev-parse --git-dir > /dev/null 2>&1; then
    CURRENT_COMMIT=$(git rev-parse --short HEAD)
    CURRENT_BRANCH=$(git branch --show-current)
    echo "  Git commit: $CURRENT_COMMIT"
    echo "  Git branch: $CURRENT_BRANCH"
fi

# Bootstrap status check
if [[ -f "/opt/ploy/bootstrap-status" ]]; then
    echo ""
    echo "🚀 Bootstrap Status:"
    cat /opt/ploy/bootstrap-status | head -5
fi

# Nomad job status
echo ""
echo "🎯 Nomad Job Status:"
export NOMAD_ADDR="http://localhost:4646"

if nomad job status ploy-api >/dev/null 2>&1; then
    JOB_STATUS=$(nomad job status -short ploy-api | grep Status | awk '{print $3}')
    echo "  Job Status: $JOB_STATUS"
    
    # Allocation details
    echo ""
    echo "📦 Allocations:"
    /opt/hashicorp/bin/nomad-job-manager.sh allocs --job ploy-api | head -10
    
    # Health check status
    echo ""
    echo "🏥 Service Health:"
    ALLOC_ID=$(/opt/hashicorp/bin/nomad-job-manager.sh running-alloc --job ploy-api)
    if [[ -n "$ALLOC_ID" ]]; then
        echo "  Allocation ID: $ALLOC_ID"
        # Get allocation status via HTTP API
        if ALLOC_STATUS=$(/opt/hashicorp/bin/nomad-job-manager.sh alloc-status --alloc-id "$ALLOC_ID" 2>/dev/null); then
            NODE_NAME=$(echo "$ALLOC_STATUS" | jq -r '.NodeName // "unknown"')
            echo "  Node: $NODE_NAME"
            
            # Get dynamic port from task resources
            DYNAMIC_PORT=$(echo "$ALLOC_STATUS" | jq -r '.Resources.Networks[0].DynamicPorts[] | select(.Label == "http") | .Value // empty')
            if [[ -n "$DYNAMIC_PORT" ]]; then
                echo "  Dynamic Port: $DYNAMIC_PORT"
            fi
        fi
    fi
else
    echo "  ❌ No API job found in Nomad"
fi

# API health check via multiple endpoints
echo ""
echo "🌐 API Health:"

# Note: API uses dynamic ports in Nomad, so we check via external domain only

# External endpoint (via Traefik)
if curl -f -s "https://api.dev.ployman.app/health" >/dev/null 2>&1; then
    echo "  ✅ External health: https://api.dev.ployman.app/health"
else
    echo "  ❌ External health unreachable: https://api.dev.ployman.app/health"
fi

# Readiness check (external only due to dynamic ports)
if curl -f -s "https://api.dev.ployman.app/ready" >/dev/null 2>&1; then
    echo "  ✅ Readiness: https://api.dev.ployman.app/ready"
else
    echo "  ❌ Readiness unreachable: https://api.dev.ployman.app/ready"
fi

# Version endpoint
echo ""
echo "📊 API Version Info:"
for endpoint in "https://api.dev.ployman.app/v1/version"; do
    if VERSION_INFO=$(curl -s "$endpoint" 2>/dev/null); then
        echo "  ✅ Version endpoint: $endpoint"
        if PARSED_VERSION=$(echo "$VERSION_INFO" | jq -r '.version // "unknown"' 2>/dev/null); then
            echo "     Version: $PARSED_VERSION"
        fi
        if PARSED_COMMIT=$(echo "$VERSION_INFO" | jq -r '.git_commit // "unknown"' 2>/dev/null); then
            echo "     Commit: $PARSED_COMMIT"
        fi
        break
    else
        echo "  ❌ Version endpoint unreachable: $endpoint"
    fi
done

# Service discovery
echo ""
echo "🔍 Service Discovery:"
if curl -s "http://localhost:8500/v1/health/service/ploy-api" >/dev/null 2>&1; then
    CONSUL_SERVICES=$(curl -s "http://localhost:8500/v1/health/service/ploy-api" | jq -r '.[] | select(.Service.Tags[] | contains("bootstrap")) | .Service.Address + ":" + (.Service.Port | tostring)' | sort | uniq)
    if [[ -n "$CONSUL_SERVICES" ]]; then
        echo "  Consul Services (bootstrap):"
        echo "$CONSUL_SERVICES" | sed 's/^/    /'
    else
        ALL_SERVICES=$(curl -s "http://localhost:8500/v1/health/service/ploy-api" | jq -r '.[].Service.Address + ":" + (.[].Service.Port | tostring)' | sort | uniq)
        echo "  Consul Services (all):"
        echo "$ALL_SERVICES" | sed 's/^/    /'
    fi
else
    echo "  ⚠️  Unable to query Consul service discovery"
fi

# Unified deployment system status
echo ""
echo "🔧 Unified Deployment System:"
if [[ -x "./bin/ployman" ]]; then
    echo "  ✅ ployman CLI available"
    
    # Try to get system status if API is accessible
    if curl -f -s "https://api.dev.ployman.app/health" >/dev/null 2>&1; then
        echo "  ✅ API accessible for deployments"
    else
        echo "  ❌ API not accessible for deployments"
    fi
else
    echo "  ⚠️  ployman CLI not found (will be built on demand)"
fi

# Recent logs (if accessible)
echo ""
echo "📋 Recent Logs:"
if [[ -n "$ALLOC_ID" ]]; then
    echo "  Last 10 log lines from allocation $ALLOC_ID:"
    /opt/hashicorp/bin/nomad-job-manager.sh logs --alloc-id "$ALLOC_ID" --lines 10 2>/dev/null | sed 's/^/    /' || echo "    Unable to fetch logs"
else
    echo "  ⚠️  No running allocation found"
fi

# Resource usage
echo ""
echo "💾 Resource Usage:"
if [[ -n "$ALLOC_ID" ]] && [[ -n "$ALLOC_STATUS" ]]; then
    echo "  CPU: $(echo "$ALLOC_STATUS" | jq -r '.Resources.CPU // "N/A"') MHz"
    echo "  Memory: $(echo "$ALLOC_STATUS" | jq -r '.Resources.MemoryMB // "N/A"') MB"
    echo "  Disk: $(echo "$ALLOC_STATUS" | jq -r '.Resources.DiskMB // "N/A"') MB"
fi

echo ""
echo "=== Status Check Complete ==="
echo ""
echo "🌐 Quick Access URLs:"
echo "  - Health: https://api.dev.ployman.app/health"
echo "  - External Health: https://api.dev.ployman.app/health"
echo "  - API Version: https://api.dev.ployman.app/v1/version"
echo "  - Nomad UI: http://127.0.0.1:4646/ui/jobs/ploy-api@default"