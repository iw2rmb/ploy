# ARF Phase 3 - Parallel Hybrid Transformation Job Template
# Optimized for parallel execution of OpenRewrite and LLM transformations

job "arf-parallel-transform-{{ transformation_id }}" {
  datacenters = ["{{ datacenter }}"]
  type = "batch"
  
  constraint {
    attribute = "${attr.kernel.name}"
    value     = "freebsd"
  }
  
  # Higher priority for parallel processing
  priority = 80
  
  group "parallel-transformation" {
    count = 1
    
    # Aggressive restart policy for parallel tasks
    restart {
      attempts = 2
      interval = "20m"
      delay    = "10s"
      mode     = "fail"
    }
    
    # Network for inter-task coordination
    network {
      mode = "bridge"
      
      port "coordinator" {
        to = 8080
      }
      
      port "openrewrite_metrics" {
        to = 9091
      }
      
      port "llm_metrics" {
        to = 9092
      }
    }
    
    # Shared volumes for parallel processing
    volume "parallel-workspace" {
      type      = "host"
      source    = "arf-workspace"
      read_only = false
    }
    
    volume "coordination" {
      type      = "host" 
      source    = "arf-coordination"
      read_only = false
    }
    
    # Coordination task - manages parallel execution
    task "coordinator" {
      driver = "exec"
      
      # Coordinator starts first
      lifecycle {
        hook = "prestart"
        sidecar = true
      }
      
      config {
        command = "/usr/local/bin/arf-parallel-coordinator"
        args = [
          "--transformation-id", "{{ transformation_id }}",
          "--strategy", "parallel",
          "--coordination-port", "8080",
          "--workspace", "/workspace",
          "--timeout", "{{ coordination_timeout | default('20m') }}",
          "--combine-strategy", "{{ combine_strategy | default('best_result') }}",
          "--confidence-weight", "{{ confidence_weight | default('0.7') }}",
          "--performance-weight", "{{ performance_weight | default('0.3') }}"
        ]
      }
      
      # Coordinator resource requirements
      resources {
        cpu    = {{ coordinator_cpu | default(500) }}
        memory = {{ coordinator_memory | default(512) }}
        disk   = {{ coordinator_disk | default(1024) }}
      }
      
      # Mount coordination volume
      volume_mount {
        volume      = "coordination"
        destination = "/coordination"
        read_only   = false
      }
      
      volume_mount {
        volume      = "parallel-workspace"
        destination = "/workspace"
        read_only   = false
      }
      
      # Coordinator configuration
      template {
        data = <<-EOH
coordination:
  transformation_id: "{{ transformation_id }}"
  parallel_tasks: 2
  combine_strategy: "{{ combine_strategy | default('best_result') }}"
  timeout: "{{ coordination_timeout | default('20m') }}"
  
  task_weights:
    openrewrite: {{ openrewrite_weight | default(0.6) }}
    llm: {{ llm_weight | default(0.4) }}
  
  success_criteria:
    min_confidence: {{ min_confidence | default(0.7) }}
    require_compilation: {{ require_compilation | default(true) }}
    max_warnings: {{ max_warnings | default(10) }}
  
  fallback:
    enabled: {{ fallback_enabled | default(true) }}
    strategy: "{{ fallback_strategy | default('openrewrite') }}"
    threshold: {{ fallback_threshold | default(0.5) }}
        EOH
        destination = "local/coordinator.yaml"
        change_mode = "restart"
      }
      
      # Environment for coordinator
      env {
        TRANSFORMATION_ID = "{{ transformation_id }}"
        COORDINATION_PORT = "8080"
        LOG_LEVEL = "{{ log_level | default('info') }}"
        METRICS_ENABLED = "{{ metrics_enabled | default('true') }}"
      }
      
      # Coordinator service
      service {
        name = "arf-coordinator-{{ transformation_id }}"
        port = "coordinator"
        
        meta {
          transformation-id = "{{ transformation_id }}"
          role = "coordinator"
          strategy = "parallel"
        }
        
        check {
          type     = "http"
          path     = "/health"
          interval = "15s"
          timeout  = "3s"
        }
      }
    }
    
    # Parallel OpenRewrite task
    task "openrewrite-parallel" {
      driver = "jail"
      
      config {
        path = "/zroot/jails/arf-or-parallel-{{ transformation_id }}"
        command = "/usr/local/bin/arf-openrewrite-executor"
        args = [
          "--recipe", "/local/openrewrite-recipe.yaml",
          "--repository", "/input/repository.tar.gz",
          "--output", "/workspace/openrewrite-result.tar.gz",
          "--coordinator-url", "http://localhost:8080",
          "--task-id", "openrewrite",
          "--parallel-mode", "true",
          "--timeout", "{{ openrewrite_timeout | default('18m') }}",
          "--metrics-port", "9091"
        ]
      }
      
      # OpenRewrite parallel resources (optimized)
      resources {
        cpu    = {{ openrewrite_parallel_cpu | default(3000) }}
        memory = {{ openrewrite_parallel_memory | default(6144) }}
        disk   = {{ openrewrite_parallel_disk | default(15360) }}
      }
      
      # Mount shared workspaces
      volume_mount {
        volume      = "parallel-workspace"
        destination = "/workspace"
        read_only   = false
      }
      
      volume_mount {
        volume      = "coordination"
        destination = "/coordination"
        read_only   = true
      }
      
      # OpenRewrite recipe
      template {
        data = <<-EOH
{{ openrewrite_recipe | to_yaml }}
        EOH
        destination = "local/openrewrite-recipe.yaml"
        change_mode = "noop"
      }
      
      # Environment for OpenRewrite parallel
      env {
        JAVA_OPTS = "-Xmx5G -XX:+UseG1GC -XX:G1HeapRegionSize=16m"
        OPENREWRITE_PARALLEL = "true"
        OPENREWRITE_CACHE_DIR = "/workspace/cache/openrewrite"
        TRANSFORMATION_ID = "{{ transformation_id }}"
        TASK_ID = "openrewrite"
        COORDINATOR_URL = "http://localhost:8080"
        METRICS_PORT = "9091"
      }
      
      # Input artifacts
      artifact {
        source = "{{ artifact_source }}/repository.tar.gz"
        destination = "input/"
        mode = "file"
      }
      
      # OpenRewrite service
      service {
        name = "arf-openrewrite-parallel-{{ transformation_id }}"
        port = "openrewrite_metrics"
        
        meta {
          transformation-id = "{{ transformation_id }}"
          task-type = "openrewrite"
          execution-mode = "parallel"
        }
        
        check {
          type     = "http"
          path     = "/metrics"
          interval = "30s"
          timeout  = "5s"
        }
      }
      
      # Resource monitoring
      logs {
        max_files     = 3
        max_file_size = 100
      }
    }
    
    # Parallel LLM task
    task "llm-parallel" {
      driver = "exec"
      
      config {
        command = "/usr/local/bin/arf-llm-parallel-executor"
        args = [
          "--repository", "/input/repository.tar.gz",
          "--context", "/local/llm-context.json",
          "--output", "/workspace/llm-result.tar.gz",
          "--coordinator-url", "http://localhost:8080",
          "--task-id", "llm",
          "--parallel-mode", "true",
          "--model", "{{ llm_model | default('gpt-4') }}",
          "--timeout", "{{ llm_timeout | default('15m') }}",
          "--metrics-port", "9092"
        ]
      }
      
      # LLM parallel resources (optimized for API calls)
      resources {
        cpu    = {{ llm_parallel_cpu | default(1500) }}
        memory = {{ llm_parallel_memory | default(3072) }}
        disk   = {{ llm_parallel_disk | default(8192) }}
      }
      
      # Mount shared workspaces
      volume_mount {
        volume      = "parallel-workspace"
        destination = "/workspace"
        read_only   = false
      }
      
      volume_mount {
        volume      = "coordination"
        destination = "/coordination"
        read_only   = true
      }
      
      # LLM context for parallel execution
      template {
        data = <<-EOH
{
  "transformation_id": "{{ transformation_id }}",
  "execution_mode": "parallel",
  "language": "{{ language }}",
  "framework": "{{ framework }}",
  "error_context": {{ error_context | to_json }},
  "codebase_context": {{ codebase_context | to_json }},
  "similar_patterns": {{ similar_patterns | to_json }},
  "constraints": {{ constraints | to_json }},
  "llm_config": {
    "model": "{{ llm_model | default('gpt-4') }}",
    "temperature": {{ llm_temperature | default(0.1) }},
    "max_tokens": {{ llm_max_tokens | default(2048) }},
    "provider": "{{ llm_provider | default('openai') }}",
    "parallel_requests": {{ parallel_requests | default(3) }},
    "batch_size": {{ batch_size | default(5) }}
  },
  "coordination": {
    "coordinator_url": "http://localhost:8080",
    "task_id": "llm",
    "progress_interval": "10s",
    "heartbeat_interval": "30s"
  }
}
        EOH
        destination = "local/llm-context.json"
        change_mode = "noop"
      }
      
      # Environment for LLM parallel
      env {
        LLM_API_KEY = "{{ llm_api_key }}"
        LLM_MODEL = "{{ llm_model | default('gpt-4') }}"
        LLM_PARALLEL = "true"
        LLM_CACHE_DIR = "/workspace/cache/llm"
        TRANSFORMATION_ID = "{{ transformation_id }}"
        TASK_ID = "llm"
        COORDINATOR_URL = "http://localhost:8080"
        METRICS_PORT = "9092"
      }
      
      # Input artifacts
      artifact {
        source = "{{ artifact_source }}/repository.tar.gz"
        destination = "input/"
        mode = "file"
      }
      
      # LLM parallel service
      service {
        name = "arf-llm-parallel-{{ transformation_id }}"
        port = "llm_metrics"
        
        meta {
          transformation-id = "{{ transformation_id }}"
          task-type = "llm"
          execution-mode = "parallel"
          model = "{{ llm_model | default('gpt-4') }}"
        }
        
        check {
          type     = "http"
          path     = "/metrics"
          interval = "45s"
          timeout  = "10s"
        }
      }
      
      # LLM monitoring
      logs {
        max_files     = 2
        max_file_size = 50
      }
    }
    
    # Result merger and validator
    task "result-merger" {
      driver = "jail"
      
      # Wait for parallel tasks to complete
      lifecycle {
        hook = "poststart"
        sidecar = false
      }
      
      config {
        path = "/zroot/jails/arf-merger-{{ transformation_id }}"
        command = "/usr/local/bin/arf-result-merger"
        args = [
          "--coordination-config", "/coordination/coordinator.yaml",
          "--openrewrite-result", "/workspace/openrewrite-result.tar.gz",
          "--llm-result", "/workspace/llm-result.tar.gz",
          "--merge-strategy", "{{ merge_strategy | default('weighted_best') }}",
          "--output", "/output/merged-result.tar.gz",
          "--report", "/output/parallel-report.json",
          "--validation", "/local/validation.yaml"
        ]
      }
      
      # Merger resource requirements
      resources {
        cpu    = {{ merger_cpu | default(2000) }}
        memory = {{ merger_memory | default(4096) }}
        disk   = {{ merger_disk | default(10240) }}
      }
      
      # Mount all workspaces
      volume_mount {
        volume      = "parallel-workspace"
        destination = "/workspace"
        read_only   = true
      }
      
      volume_mount {
        volume      = "coordination"
        destination = "/coordination"
        read_only   = true
      }
      
      # Validation and merging configuration
      template {
        data = <<-EOH
merging:
  strategy: "{{ merge_strategy | default('weighted_best') }}"
  weights:
    openrewrite_confidence: {{ openrewrite_confidence_weight | default(0.6) }}
    llm_confidence: {{ llm_confidence_weight | default(0.4) }}
    execution_time: {{ execution_time_weight | default(0.2) }}
    test_coverage: {{ test_coverage_weight | default(0.3) }}
  
  selection_criteria:
    min_confidence_diff: {{ min_confidence_diff | default(0.1) }}
    max_time_diff: {{ max_time_diff | default('5m') }}
    prefer_higher_confidence: {{ prefer_higher_confidence | default(true) }}
  
validation:
  compile_both: {{ validate_both | default(true) }}
  test_both: {{ test_both | default(false) }}
  security_scan: {{ security_scan_merged | default(true) }}
  
  final_criteria:
    min_merged_confidence: {{ min_merged_confidence | default(0.75) }}
    max_critical_issues: {{ max_critical_issues | default(0) }}
    require_improvement: {{ require_improvement | default(true) }}
        EOH
        destination = "local/validation.yaml"
        change_mode = "noop"
      }
      
      # Environment for merger
      env {
        TRANSFORMATION_ID = "{{ transformation_id }}"
        MERGE_STRATEGY = "{{ merge_strategy | default('weighted_best') }}"
        LANGUAGE = "{{ language }}"
        FRAMEWORK = "{{ framework }}"
      }
      
      # Final result upload
      artifact {
        source = "output/"
        destination = "{{ result_destination }}"
        mode = "dir"
      }
      
      # Merger service
      service {
        name = "arf-merger-{{ transformation_id }}"
        
        meta {
          transformation-id = "{{ transformation_id }}"
          stage = "merging"
          strategy = "parallel"
          final-step = "true"
        }
      }
    }
  }
  
  # Parameterized job for dynamic dispatch
  parameterized {
    payload       = "optional"
    meta_required = [
      "transformation_id", 
      "language", 
      "openrewrite_recipe",
      "llm_context"
    ]
    meta_optional = [
      "framework", 
      "llm_model", 
      "merge_strategy",
      "timeout",
      "coordination_timeout"
    ]
  }
  
  # Job metadata
  meta {
    version = "{{ job_version | default('1.0.0') }}"
    arf_phase = "3"
    transformation_type = "parallel_hybrid"
    optimization = "high_performance"
    created_by = "arf-api"
    created_at = "{{ ansible_date_time.iso8601 }}"
  }
}