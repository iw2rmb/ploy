# Log rotation configuration for CHTTP services
# Generated by Ansible for {{ ansible_hostname }}

{{ chttp_log_dir }}/*.log {
    daily
    missingok
    rotate 30
    compress
    delaycompress
    notifempty
    create 0644 {{ chttp_user }} {{ chttp_user }}
    postrotate
        # Reload all CHTTP services to reopen log files
        for service in {% for svc in chttp_services %}{{ svc.name }} {% endfor %}; do
            /bin/systemctl reload $service > /dev/null 2>&1 || true
        done
    endscript
}

{{ chttp_log_dir }}/*.error.log {
    daily
    missingok
    rotate 30
    compress
    delaycompress
    notifempty
    create 0644 {{ chttp_user }} {{ chttp_user }}
}