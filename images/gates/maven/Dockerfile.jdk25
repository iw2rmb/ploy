ARG JAVA_BASE_MAVEN_25_IMAGE=java-base-maven:jdk25
FROM ${JAVA_BASE_MAVEN_25_IMAGE}

LABEL org.opencontainers.image.title="ploy-gate-maven-jdk25" \
    org.opencontainers.image.description="Ploy Maven gate runner image with Maven 3 and Eclipse Temurin JDK 25"

ENV MAVEN_CONFIG=/root/.m2

COPY --chmod=755 images/gates/shared/collect-java-classpath-maven.sh /usr/local/lib/ploy/sbom/collect-java-classpath-maven.sh
