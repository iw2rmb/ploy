datacenter = "dc1"
data_dir = "/opt/hashicorp/nomad"
log_level = "INFO"
name = "ploy-dev-node"

# Enable metrics for monitoring
telemetry {
  prometheus_metrics = true
  publish_allocation_metrics = true
  publish_node_metrics = true
}

server {
  enabled = true
  bootstrap_expect = 1
  
  # Enhanced server configuration for Ploy
  default_scheduler_config {
    scheduler_algorithm = "spread"
    preemption_config {
      batch_scheduler_enabled = true
      system_scheduler_enabled = true
      service_scheduler_enabled = false
    }
  }
}

client {
  enabled = true
  servers = ["127.0.0.1"]
  
  # Enhanced client configuration for Ploy lanes
  options {
    "driver.raw_exec.enable" = "1"
    "driver.exec.enable" = "1"
    "driver.java.enable" = "1"
  }
  
  # Resource configuration
  reserved {
    cpu = 100
    memory = 256
    disk = 1024
  }
  
  # Host volumes for persistent storage
  host_volume "ploy-artifacts" {
    path      = "/opt/ploy/artifacts"
    read_only = false
  }
  
  host_volume "ploy-logs" {
    path      = "/opt/ploy/logs"
    read_only = false
  }
}

consul {
  address = "127.0.0.1:8500"
}

vault {
  enabled = false
  address = "http://127.0.0.1:8200"
}

plugin "docker" {
  config {
    enabled = true
    allow_privileged = true
    
    # Allow Kontain runtime
    allow_runtimes = ["runc", "io.kontain"]
  }
}

ui {
  enabled = true
}

ports {
  http = 4646
  rpc = 4647
  serf = 4648
}