{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/mods/plan.schema.json",
  "title": "Planner Output Plan",
  "type": "object",
  "required": ["plan_id", "options"],
  "properties": {
    "plan_id": { "type": "string" },
    "options": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "type"],
        "properties": {
          "id": { "type": "string" },
          "type": { "enum": ["human-step", "llm-exec", "orw-gen"] },
          "description": { "type": "string" },
          "recipes": { "type": "array", "items": { "type": "string" } },
          "prompt": { "type": "string" },
          "tool_params": { "type": "object" },
          "metadata": { "type": "object" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}

