# Pylint CHTTP Service Configuration
# Generated by Ansible for {{ ansible_hostname }}
service:
  name: "pylint-chttp"
  port: {{ item.port | default(8080) }}
  listen_addr: "0.0.0.0:{{ item.port | default(8080) }}"

executable:
  path: "python3"
  args: ["-m", "pylint", "--output-format=json", "--reports=no", "--score=no", "--msg-template={path}:{line}:{column}: {msg_id}: {msg} ({symbol})"]
  timeout: "5m"
  working_dir: "/tmp/chttp"

security:
  auth_method: "{% if chttp_auth_disabled | default(false) %}disabled{% else %}public_key{% endif %}"
  {% if not (chttp_auth_disabled | default(false)) %}
  public_key_path: "{{ chttp_config_dir }}/public.pem"
  {% endif %}
  run_as_user: "{{ chttp_user }}"
  max_memory: "512MB"
  max_cpu: "1.0"
  sandbox_enabled: true
  temp_dir: "/tmp/chttp"

input:
  formats: ["tar.gz", "tar", "zip"]
  allowed_extensions: [".py", ".pyw", ".py3"]
  max_archive_size: "100MB"
  max_files: 1000
  excluded_paths: ["__pycache__", ".git", ".pytest_cache", "*.pyc", "venv", ".venv", "env", ".env"]

output:
  format: "json" 
  parser: "pylint_json"
  include_stats: false

logging:
  level: "{{ chttp_log_level | default('info') }}"
  format: "json"
  output: "{{ chttp_log_dir }}/{{ item.name }}.log"

# VPS environment specific settings
{% if ansible_hostname is defined %}
environment:
  hostname: "{{ ansible_hostname }}"
  deployment_type: "vps"
  region: "{{ ansible_default_ipv4.address | default('unknown') }}"
{% endif %}

# Performance tuning for VPS environment
performance:
  max_concurrent_analyses: 3
  analysis_timeout: "300s"
  cleanup_interval: "1h"
  temp_retention: "2h"