{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ploy.local/java/openrewrite-coverage.schema.json",
  "title": "OpenRewrite Plan Coverage",
  "type": "object",
  "additionalProperties": false,
  "required": ["generatedAt", "inputReport", "summary", "changes"],
  "properties": {
    "generatedAt": { "type": "string", "format": "date-time" },
    "inputReport": { "type": "string" },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["totalChanges", "coveredFully", "coveredPartially", "uncovered"],
      "properties": {
        "totalChanges": { "type": "integer", "minimum": 0 },
        "coveredFully": { "type": "integer", "minimum": 0 },
        "coveredPartially": { "type": "integer", "minimum": 0 },
        "uncovered": { "type": "integer", "minimum": 0 }
      }
    },
    "changes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "changeId",
          "updateGA",
          "class",
          "member",
          "type",
          "coverage",
          "selectedRecipe",
          "bestScore",
          "topCandidates"
        ],
        "properties": {
          "changeId": { "type": "string" },
          "updateGA": { "type": "string" },
          "class": { "type": "string" },
          "member": { "type": ["string", "null"] },
          "type": { "type": "string" },
          "coverage": { "type": "string", "enum": ["covered_fully", "covered_partially", "uncovered"] },
          "selectedRecipe": { "type": ["string", "null"] },
          "bestScore": { "type": "number" },
          "topCandidates": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["name", "score", "composite", "displayName", "artifact"],
              "properties": {
                "name": { "type": "string" },
                "score": { "type": "number" },
                "composite": { "type": "boolean" },
                "displayName": { "type": ["string", "null"] },
                "artifact": {
                  "type": ["object", "null"],
                  "additionalProperties": false,
                  "required": ["group", "artifact", "version"],
                  "properties": {
                    "group": { "type": "string" },
                    "artifact": { "type": "string" },
                    "version": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
