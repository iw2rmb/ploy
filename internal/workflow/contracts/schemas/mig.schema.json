{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/iw2rmb/ploy/schemas/mig.schema.json",
  "title": "Ploy mig spec",
  "type": "object",
  "required": ["steps"],
  "additionalProperties": true,
  "properties": {
    "apiVersion": { "type": "string" },
    "name": { "type": "string", "pattern": "^[0-9a-z._-]+$" },
    "description": { "type": "string" },
    "job_id": { "type": "string" },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/step" }
    },
    "envs": { "$ref": "#/definitions/stringMap" },
    "build_gate": { "$ref": "#/definitions/buildGate" },
    "bundle_map": { "$ref": "#/definitions/stringMap" }
  },
  "definitions": {
    "stringMap": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "release": {
      "oneOf": [
        { "type": "string" },
        { "type": "number" }
      ]
    },
    "image": {
      "oneOf": [
        { "type": "string" },
        { "$ref": "#/definitions/stringMap" }
      ]
    },
    "command": {
      "oneOf": [
        { "type": "string" },
        {
          "type": "array",
          "items": { "type": "string" }
        }
      ]
    },
    "hydraEntries": {
      "type": "array",
      "items": { "type": "string" }
    },
    "stackExpectation": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "language": { "type": "string" },
        "tool": { "type": "string" },
        "release": { "$ref": "#/definitions/release" }
      }
    },
    "stepStackPhase": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "expect": { "$ref": "#/definitions/stackExpectation" }
      }
    },
    "stepStack": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "inbound": { "$ref": "#/definitions/stepStackPhase" },
        "outbound": { "$ref": "#/definitions/stepStackPhase" }
      }
    },
    "stepOptions": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "mount_docker_socket": { "type": "boolean" }
      }
    },
    "step": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "name": { "type": "string" },
        "image": { "$ref": "#/definitions/image" },
        "command": { "$ref": "#/definitions/command" },
        "envs": { "$ref": "#/definitions/stringMap" },
        "options": { "$ref": "#/definitions/stepOptions" },
        "in": { "$ref": "#/definitions/hydraEntries" },
        "out": { "$ref": "#/definitions/hydraEntries" },
        "home": { "$ref": "#/definitions/hydraEntries" },
        "tmp": { "$ref": "#/definitions/hydraEntries" },
        "stack": { "$ref": "#/definitions/stepStack" }
      }
    },
    "buildGateStack": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "mode": { "type": "string", "enum": ["forced", "strict", "fallback"] },
        "language": { "type": "string" },
        "tool": { "type": "string" },
        "release": { "$ref": "#/definitions/release" }
      },
      "allOf": [
        {
          "if": {
            "required": ["mode"],
            "properties": { "mode": { "enum": ["forced", "fallback"] } }
          },
          "then": { "required": ["language", "tool", "release"] }
        },
        {
          "if": {
            "required": ["mode"],
            "properties": { "mode": { "const": "strict" } }
          },
          "then": {
            "anyOf": [
              { "required": ["language"] },
              { "required": ["tool"] },
              { "required": ["release"] }
            ]
          }
        },
        {
          "if": { "not": { "required": ["mode"] } },
          "then": {
            "not": {
              "anyOf": [
                { "required": ["language"] },
                { "required": ["tool"] },
                { "required": ["release"] }
              ]
            }
          }
        }
      ]
    },
    "buildGatePhase": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "stack": { "$ref": "#/definitions/buildGateStack" }
      }
    },
    "buildGateImageRule": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "stack": { "$ref": "#/definitions/stackExpectation" },
        "image": { "type": "string" }
      }
    },
    "buildGate": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "disabled": { "type": "boolean" },
        "pre": { "$ref": "#/definitions/buildGatePhase" },
        "post": { "$ref": "#/definitions/buildGatePhase" },
        "images": {
          "type": "array",
          "items": { "$ref": "#/definitions/buildGateImageRule" }
        }
      }
    }
  }
}
