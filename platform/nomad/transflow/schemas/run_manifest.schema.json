{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/transflow/run_manifest.schema.json",
  "title": "Transflow Run Manifest",
  "type": "object",
  "required": ["id", "repo", "lane", "timestamps", "build_gate"],
  "properties": {
    "id": { "type": "string" },
    "repo": {
      "type": "object",
      "required": ["url", "base_ref", "workflow_branch"],
      "properties": {
        "url": { "type": "string" },
        "base_ref": { "type": "string" },
        "workflow_branch": { "type": "string" }
      },
      "additionalProperties": false
    },
    "lane": { "type": "string" },
    "timestamps": {
      "type": "object",
      "properties": {
        "started_at": { "type": "string", "format": "date-time" },
        "finished_at": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": false
    },
    "build_gate": {
      "type": "object",
      "required": ["status"],
      "properties": {
        "status": { "enum": ["pass", "fail"] },
        "stdout": { "type": "string" },
        "stderr": { "type": "string" }
      },
      "additionalProperties": false
    },
    "planner": {
      "type": "object",
      "properties": {
        "stdout": { "type": "string" },
        "plan_path": { "type": "string" }
      },
      "additionalProperties": true
    },
    "branches": {
      "type": "array",
      "items": { "$ref": "branch_record.schema.json" }
    },
    "reducer": {
      "type": "object",
      "properties": {
        "stdout": { "type": "string" },
        "next_path": { "type": "string" }
      },
      "additionalProperties": true
    },
    "kb_updates": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}
