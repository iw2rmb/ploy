FROM python:{{ .PythonVersion }}-slim AS build
WORKDIR /workspace
ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

RUN mkdir -p /out/site

COPY . .

RUN if [ -f requirements.txt ] && [ -s requirements.txt ]; then \
      pip install --no-cache-dir -r requirements.txt --target /out/site; \
    fi

RUN if [ -f pyproject.toml ] || [ -f setup.py ]; then \
      pip install --no-cache-dir . --target /out/site; \
    fi

RUN mkdir -p /out/app && cp -R . /out/app
