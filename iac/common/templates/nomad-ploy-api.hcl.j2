# Ploy API - High Availability Nomad Job
# 
# This job deploys the Ploy API with:
# - High availability across multiple nodes
# - Rolling updates with health checks
# - Binary distribution via SeaweedFS
# - Service discovery integration
# - Load balancing via Traefik

job "ploy-api" {
  datacenters = ["dc1"]
  type = "service"
  priority = 80

  # High availability configuration
  # Run multiple instances across different nodes (production) or single instance (dev)
  group "api" {
    {% if ploy_environment is defined and ploy_environment == 'dev' %}
    count = {{ nomad_api.replicas | default(1) }}
    {% else %}
    count = {{ nomad_api.replicas | default(2) }}

    # Spread across different nodes for availability (production only)
    constraint {
      distinct_hosts = true
    }
    {% endif %}

    # Rolling update configuration
    update {
      max_parallel = 1
      min_healthy_time = "30s"
      healthy_deadline = "5m"
      progress_deadline = "10m"
      auto_revert = true
      canary = 1
    }

    # Network configuration (moved from task level to group level)
    network {
      port "http" {}  # Dynamic port allocation
    }

    # Restart policy
    restart {
      attempts = 3
      interval = "10m"
      delay = "30s"
      mode = "fail"
    }

    task "api" {
      driver = "raw_exec"

      # Binary distribution via artifact download from SeaweedFS
      artifact {
        source = "http://localhost:{{ seaweedfs.filer_port }}/ploy-artifacts/api-binaries/{{ api_version }}/linux/amd64/api"
        destination = "local/api"
        mode = "file"
      }

      # Configuration for raw_exec driver
      config {
        command = "/bin/bash"
        args = ["local/start-api.sh"]
      }


      # Resource allocation
      resources {
        cpu = {{ nomad_api.resources.cpu | default(500) }}
        memory = {{ nomad_api.resources.memory | default(512) }}
      }

      # Environment configuration
      env {
        # API configuration - using dynamic port
        PORT = "${NOMAD_PORT_http}"
        PLOY_CONTROLLER = "https://api.dev.{{ ploy.platform_domain }}/v1"
        PLOY_STORAGE_CONFIG = "/etc/ploy/storage/config.yaml"
        
        # HashiCorp service addresses
        CONSUL_ADDR = "http://localhost:8500"
        NOMAD_ADDR = "http://localhost:4646"
        VAULT_ADDR = "http://localhost:8200"

        # SeaweedFS configuration
        SEAWEEDFS_MASTER = "localhost:{{ seaweedfs.master_port }}"
        SEAWEEDFS_FILER = "localhost:{{ seaweedfs.filer_port }}"

        # ARF (Automated Remediation Framework) configuration
        ARF_FREEBSD_HOST = "{{ freebsd_vm_dynamic_ip | default(freebsd_vm.ip | default('192.168.100.10')) }}"
        ARF_FREEBSD_USER = "root"
        ARF_FREEBSD_PORT = "22"
        ARF_JAIL_BASE_DIR = "/jail"
        ARF_JAIL_TEMPLATE_DIR = "/jail/template"
        ARF_JAIL_INTERFACE = "lo0"
        
        # OpenRewrite configuration for transformations
        JAVA_HOME = "/usr/lib/jvm/java-17-openjdk-amd64"
        ARF_OPENREWRITE_JAR = "/usr/local/bin/rewrite-maven.jar"
        ARF_WORKING_DIR = "/tmp/arf"
        
        # ARF Phase 3 - LLM Integration & Learning System
        ARF_LEARNING_DB_URL = "postgres://ploy:{{ arf_db_password | default('arf_dev_password') }}@localhost/arf_learning?sslmode=disable"
        ARF_TREE_SITTER_PATH = "/usr/local/bin/tree-sitter"
        ARF_LLM_CACHE_DIR = "/tmp/arf-llm-cache"
        ARF_AB_TEST_DIR = "/tmp/arf-ab-tests"
        TREE_SITTER_PARSER_DIR = "/usr/local/lib/node_modules"
        
        # LLM API Configuration (use Vault secrets in production)
        LLM_PROVIDER = "{{ llm_provider | default('openai') }}"
        LLM_MODEL = "{{ llm_model | default('gpt-4') }}"
        LLM_API_KEY = "{{ vault_llm_api_key | default('') }}"
        LLM_MAX_TOKENS = "{{ llm_max_tokens | default('2048') }}"
        LLM_TEMPERATURE = "{{ llm_temperature | default('0.1') }}"

        # Platform wildcard certificate configuration
        PLOY_APPS_DOMAIN = "{{ ploy.apps_domain }}"
        PLOY_APPS_DOMAIN_PROVIDER = "{{ ploy.apps_domain_provider }}"
        
        # Development environment wildcard certificate (*.dev.ployd.app)
        # This is for DEV environment ONLY
        {% if ploy_environment is defined and ploy_environment == 'dev' %}
        PLOY_DEV_SUBDOMAIN = "dev"
        PLOY_DEV_APPS_DOMAIN = "dev.{{ ploy.apps_domain }}"
        PLOY_WILDCARD_DOMAIN = "*.dev.{{ ploy.apps_domain }}"
        PLOY_API_DOMAIN = "api.dev.{{ ploy.apps_domain }}"
        PLOY_ENVIRONMENT = "dev"
        {% endif %}
        
        # DNS provider credentials (from Vault in production)
        {% if ploy.apps_domain_provider == 'namecheap' %}
        NAMECHEAP_API_USER = "{{ vault_namecheap_api_user | default('') }}"
        NAMECHEAP_API_KEY = "{{ vault_namecheap_api_key | default('') }}"
        {% elif ploy.apps_domain_provider == 'cloudflare' %}
        CLOUDFLARE_API_TOKEN = "{{ vault_cloudflare_api_token | default('') }}"
        {% endif %}
        
        # GitHub credentials for repository access
        GITHUB_PLOY_DEV_USERNAME = "{{ lookup('env', 'GITHUB_PLOY_DEV_USERNAME') }}"
        GITHUB_PLOY_DEV_PAT = "{{ lookup('env', 'GITHUB_PLOY_DEV_PAT') }}"
        
        # Deployment metadata
        PLOY_DEPLOYMENT_METHOD = "nomad"
        PLOY_NODE_ID = "${node.unique.name}"
      }

      # Make binary executable and start
      template {
        data = <<EOF
#!/bin/bash
chmod +x local/api
exec local/api
EOF
        destination = "local/start-api.sh"
        perms = "755"
      }

      # Health checks
      service {
        name = "ploy-api"
        port = "http"
        tags = [
          "api",
          "ploy-api",
          "traefik.enable=true",
          "traefik.http.routers.ploy-api.rule=Host(`api.dev.ployman.app`)",
          "traefik.http.routers.ploy-api.tls=true",
          "traefik.http.routers.ploy-api.tls.certresolver=dev-wildcard"
        ]

        # Health check endpoint
        check {
          type = "http"
          path = "/health"
          interval = "10s"
          timeout = "3s"
          check_restart {
            limit = 3
            grace = "10s"
            ignore_warnings = false
          }
        }

        # Readiness check
        check {
          name = "readiness"
          type = "http"
          path = "/ready"
          interval = "15s"
          timeout = "5s"
        }
      }

      # Graceful shutdown
      kill_timeout = "30s"
      kill_signal = "SIGTERM"

      # Logging configuration
      logs {
        max_files = 10
        max_file_size = 10
      }
    }
  }
}