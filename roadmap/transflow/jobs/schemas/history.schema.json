{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/transflow/history.schema.json",
  "title": "Reducer History",
  "type": "object",
  "required": ["plan_id", "branches", "winner"],
  "properties": {
    "plan_id": { "type": "string" },
    "branches": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "status"],
        "properties": {
          "id": { "type": "string" },
          "status": { "enum": ["success", "failed", "canceled", "timeout"] },
          "artifact": { "type": "string" },
          "notes": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "winner": { "type": "string" }
  },
  "additionalProperties": false
}

