FROM eclipse-temurin:{{ .JavaVersion }}-jdk AS build
WORKDIR /src
COPY . .
# Compile all Java sources under conventional layout; ignore tests
RUN if [ -d src/main/java ]; then \
      find src/main/java -name "*.java" -print0 | xargs -0 javac -d /out; \
    else \
      echo "No src/main/java found"; \
    fi

FROM eclipse-temurin:{{ .JavaVersion }}-jre-alpine
WORKDIR /app
COPY --from=build /out /app
ENV PORT=8080
EXPOSE 8080
{{- if .MainClass }}
ENTRYPOINT ["java","-cp","/app","{{ .MainClass }}"]
{{- else }}
CMD ["sh","-lc","echo 'Set MainClass to run application' && sleep 30"]
{{- end }}
