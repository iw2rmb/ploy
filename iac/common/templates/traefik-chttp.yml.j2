# Traefik dynamic configuration for CHTTP services
# Generated by Ansible for {{ ansible_hostname }}

http:
  routers:
{% for service in chttp_services %}
    {{ service.name }}:
      rule: "Host(`{{ service.name }}.chttp.{{ ploy_domain | default('dev.ployd.app') }}`)"
      service: "{{ service.name }}"
      entryPoints:
        - "websecure"
      tls:
        certResolver: "letsencrypt"
      middlewares:
        - "chttp-headers"
        - "chttp-ratelimit"

    {{ service.name }}-api:
      rule: "Host(`api.{{ ploy_domain | default('dev.ployd.app') }}`) && PathPrefix(`/chttp/{{ service.name }}`)"
      service: "{{ service.name }}"
      entryPoints:
        - "websecure"
      tls:
        certResolver: "letsencrypt"
      middlewares:
        - "chttp-headers"
        - "chttp-ratelimit"
        - "chttp-stripprefix"
{% endfor %}

  services:
{% for service in chttp_services %}
    {{ service.name }}:
      loadBalancer:
        servers:
          - url: "http://127.0.0.1:{{ service.port }}"
        healthCheck:
          path: "/health"
          interval: "30s"
          timeout: "5s"
          scheme: "http"
{% endfor %}

  middlewares:
    chttp-headers:
      headers:
        customRequestHeaders:
          X-Forwarded-Proto: "https"
          X-Forwarded-Host: "{{ ploy_domain | default('dev.ployd.app') }}"
        customResponseHeaders:
          X-CHTTP-Service: "ploy-static-analysis"
          X-Content-Type-Options: "nosniff"
          X-Frame-Options: "DENY"
          X-XSS-Protection: "1; mode=block"
          Referrer-Policy: "strict-origin-when-cross-origin"
        accessControlAllowOriginList:
          - "https://api.{{ ploy_domain | default('dev.ployd.app') }}"

    chttp-ratelimit:
      rateLimit:
        burst: 10
        average: 5
        period: "1m"

    chttp-stripprefix:
      stripPrefix:
        prefixes:
          - "/chttp"

# TCP routing for direct CHTTP access (if needed)
tcp:
  routers:
{% for service in chttp_services %}
    {{ service.name }}-tcp:
      rule: "HostSNI(`{{ service.name }}.chttp.{{ ploy_domain | default('dev.ployd.app') }}`)"
      service: "{{ service.name }}-tcp"
      entryPoints:
        - "chttp-tcp"
      tls:
        passthrough: false
{% endfor %}

  services:
{% for service in chttp_services %}
    {{ service.name }}-tcp:
      loadBalancer:
        servers:
          - address: "127.0.0.1:{{ service.port }}"
{% endfor %}