# Dynamic Traefik configuration for Ploy API with wildcard SSL certificates
# ACME DNS-01 is used via configured resolvers (apps-wildcard, platform-wildcard).

http:
  routers:
    # Wildcard certificate request for apps domain (e.g., *.dev.ployd.app)
    apps-wildcard-cert:
      rule: "HostRegexp(`{app:[a-z0-9-]+}.{{ ploy.apps_domain }}`)"
      entryPoints:
        - acme
      service: noop-service
      tls:
        certResolver: "apps-wildcard"
        domains:
          - main: "{{ ploy.apps_domain }}"
            sans:
              - "*.{{ ploy.apps_domain }}"
      priority: -100

    # Wildcard certificate request for platform services (e.g., *.dev.ployman.app)
    platform-wildcard-cert:
      rule: "HostRegexp(`{service:[a-z0-9-]+}.{{ ploy.platform_domain }}`)"
      entryPoints:
        - acme
      service: noop-service
      tls:
        certResolver: "platform-wildcard"
        domains:
          - main: "{{ ploy.platform_domain }}"
            sans:
              - "*.{{ ploy.platform_domain }}"
      priority: -100

  services:
    # Noop service for certificate provisioning only
    noop-service:
      loadBalancer:
        servers:
          - url: "http://127.0.0.1:65535"

  middlewares:
    https-redirect:
      redirectScheme:
        scheme: https
        permanent: true
    
    secure-headers:
      headers:
        accessControlAllowMethods:
          - GET
          - OPTIONS  
          - PUT
          - POST
          - DELETE
        accessControlMaxAge: 100
        hostsProxyHeaders:
          - "X-Forwarded-Host"
        referrerPolicy: "same-origin"
        sslRedirect: true
        sslHost: ""
        sslForceHost: false
        stsSeconds: 31536000
        stsIncludeSubdomains: true
        stsPreload: true
        forceSTSHeader: true
        contentTypeNosniff: true
        browserXssFilter: true
        customFrameOptionsValue: "SAMEORIGIN"

# TLS configuration (no static certificates; rely on ACME resolvers)
tls:
  options:
    default:
      minVersion: "VersionTLS12"
      cipherSuites:
        - "TLS_ECDHE_RSA_WITH_AES_256_GCM_SHA384"
        - "TLS_ECDHE_RSA_WITH_CHACHA20_POLY1305"
        - "TLS_ECDHE_RSA_WITH_AES_128_GCM_SHA256"
        - "TLS_RSA_WITH_AES_256_GCM_SHA384"
        - "TLS_RSA_WITH_AES_128_GCM_SHA256"
