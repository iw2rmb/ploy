{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/iw2rmb/ploy/docs/schemas/integration_manifest.schema.json",
  "title": "Ploy Integration Manifest",
  "description": "Schema describing integration manifests that capture services, topology edges, exposures, fixtures, lanes, and Aster toggles for the workflow runner.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "manifest_version",
    "name",
    "version",
    "summary",
    "topology",
    "fixtures",
    "lanes",
    "services",
    "edges"
  ],
  "properties": {
    "manifest_version": {
      "type": "string",
      "const": "v2",
      "description": "Schema version identifier for integration manifests."
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Manifest identifier (e.g. commit-app, smoke)."
    },
    "version": {
      "type": "string",
      "minLength": 1,
      "description": "Semantic or date-based manifest version."
    },
    "summary": {
      "type": "string",
      "minLength": 1,
      "description": "Markdown summary explaining the manifest purpose and guidance."
    },
    "topology": {
      "type": "object",
      "additionalProperties": false,
      "required": ["description"],
      "properties": {
        "description": {
          "type": "string",
          "description": "Markdown description of the topology intent."
        },
        "allow": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["from", "to"],
            "properties": {
              "from": {
                "type": "string",
                "minLength": 1
              },
              "to": {
                "type": "string",
                "minLength": 1
              },
              "reason": {
                "type": "string"
              }
            }
          }
        },
        "deny": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["from", "to", "reason"],
            "properties": {
              "from": {
                "type": "string",
                "minLength": 1
              },
              "to": {
                "type": "string",
                "minLength": 1
              },
              "reason": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    },
    "fixtures": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required"],
      "properties": {
        "required": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "reference"],
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "reference": {
                "type": "string",
                "minLength": 1
              },
              "reason": {
                "type": "string"
              }
            }
          }
        },
        "optional": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "reference"],
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "reference": {
                "type": "string",
                "minLength": 1
              },
              "reason": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "lanes": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required"],
      "properties": {
        "required": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "reason"],
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "reason": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "allowed": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name"],
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "reason": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "aster": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "required": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "optional": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      }
    },
    "services": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "kind", "identity", "ports"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string",
            "minLength": 1
          },
          "optional": {
            "type": "boolean"
          },
          "identity": {
            "type": "object",
            "additionalProperties": false,
            "required": ["dns"],
            "properties": {
              "dns": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "ports": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["name", "port", "protocol"],
              "properties": {
                "name": {
                  "type": "string",
                  "minLength": 1
                },
                "port": {
                  "type": "integer",
                  "minimum": 1
                },
                "protocol": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          },
          "requires": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["target", "edge"],
              "properties": {
                "target": {
                  "type": "string",
                  "minLength": 1
                },
                "edge": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        }
      }
    },
    "edges": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["source", "target", "ports", "protocols"],
        "properties": {
          "source": {
            "type": "string",
            "minLength": 1
          },
          "target": {
            "type": "string",
            "minLength": 1
          },
          "ports": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          },
          "protocols": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          }
        }
      }
    },
    "exposures": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["service", "port", "mode"],
        "properties": {
          "service": {
            "type": "string",
            "minLength": 1
          },
          "port": {
            "type": "string",
            "minLength": 1
          },
          "mode": {
            "type": "string",
            "enum": ["public", "cluster", "local"]
          }
        }
      }
    }
  }
}
