ARG JAVA_BASE_MAVEN_21_IMAGE=java-base-maven:jdk21
FROM ${JAVA_BASE_MAVEN_21_IMAGE}

LABEL org.opencontainers.image.title="ploy-gate-maven-jdk21" \
    org.opencontainers.image.description="Ploy Maven gate runner image with Maven 3 and Eclipse Temurin JDK 21" \
    org.opencontainers.image.source="https://github.com/iw2rmb/ploy" \
    org.opencontainers.image.licenses="MIT"

ENV MAVEN_CONFIG=/root/.m2

COPY --chmod=755 images/gates/shared/collect-java-classpath-maven.sh /usr/local/lib/ploy/sbom/collect-java-classpath-maven.sh
