FROM gradle:8.8-jdk11
LABEL org.opencontainers.image.title="ploy-gate-gradle-jdk11" \
    org.opencontainers.image.description="Ploy Gradle gate runner image with Gradle 8.8 and JDK 11" \
    org.opencontainers.image.source="https://github.com/iw2rmb/ploy" \
    org.opencontainers.image.licenses="MIT"

COPY gradle.properties /root/.gradle/gradle.properties
COPY cache.init.gradle /root/.gradle/init.d/cache.init.gradle
