#!/bin/bash
# Setup Ploy development environment

echo "Setting up Ploy development environment..."

# Set environment variables
# Ensure basic system directories are in PATH
export PATH="/usr/local/go/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:$PATH"
export PLOY_CONTROLLER="http://localhost:{{ ploy.controller_port }}/v1"
export GOOS=linux
export GOARCH=amd64

# GitHub environment variables for Ploy development
export GITHUB_PLOY_DEV_USERNAME="{{ lookup('env', 'GITHUB_PLOY_DEV_USERNAME') }}"
export GITHUB_PLOY_DEV_PAT="{{ lookup('env', 'GITHUB_PLOY_DEV_PAT') }}"

# Create necessary directories
mkdir -p ~/ploy-testing
cd ~/ploy-testing

echo "Environment setup completed!"
echo ""
echo "Available tools:"
echo "  - Ploy Controller: ~/ploy/ploy-controller"
echo "  - Ploy CLI: ~/ploy/ploy"  
echo "  - Lane Picker: ~/ploy/lane-pick"
echo "  - Test Scripts: ~/test-scripts/"
echo ""
echo "Services:"
echo "  - MinIO Console: http://localhost:{{ minio.console_port }}"
echo "  - Nomad UI: http://localhost:4646"
echo "  - Consul UI: http://localhost:8500"
echo "  - Vault UI: http://localhost:8200"
echo ""
echo "Run 'source ~/setup-env.sh' to set environment variables"