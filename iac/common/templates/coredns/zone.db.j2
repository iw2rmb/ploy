$TTL {{ coredns.ttl | default(300) }}
@   IN  SOA {{ coredns.zone }}. {{ coredns.soa_rname | default('hostmaster.' ~ coredns.zone ~ '.') }} (
        {{ coredns.serial | default('2025010100') }} ; Serial
        {{ coredns.refresh | default(3600) }}       ; Refresh
        {{ coredns.retry | default(1200) }}        ; Retry
        {{ coredns.expire | default(604800) }}     ; Expire
        {{ coredns.minimum | default(300) }}       ; Minimum TTL
)
    IN  NS  {{ coredns.ns | default('ns1.' ~ coredns.zone ~ '.') }}

{{ coredns.ns_host | default('ns1') }}    IN  A   {{ coredns.service_ip }}

{% for record in coredns.a_records | default([]) %}
{{ record.name }}    {{ record.ttl | default(coredns.ttl | default(300)) }} IN  A   {{ record.target }}
{% endfor %}
{% for record in coredns.cname_records | default([]) %}
{{ record.name }}    {{ record.ttl | default(coredns.ttl | default(300)) }} IN  CNAME {{ record.target }}
{% endfor %}
{% for record in coredns.srv_records | default([]) %}
{{ record.name }}    {{ record.ttl | default(coredns.ttl | default(300)) }} IN  SRV {{ record.priority | default(10) }} {{ record.weight | default(10) }} {{ record.port }} {{ record.target }}
{% endfor %}
