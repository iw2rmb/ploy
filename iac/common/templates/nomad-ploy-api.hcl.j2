# Ploy API - High Availability Nomad Job
# 
# This job deploys the Ploy API with:
# - High availability across multiple nodes
# - Rolling updates with health checks
# - Binary distribution via SeaweedFS
# - Service discovery integration
# - Load balancing via Traefik

job "ploy-api" {
  datacenters = ["dc1"]
  type = "service"
  priority = 80

  # High availability configuration
  # Run multiple instances across different nodes (production) or single instance (dev)
  group "api" {
    {% if ploy_environment is defined and ploy_environment == 'dev' %}
    count = {{ nomad_api.replicas | default(1) }}
    {% else %}
    count = {{ nomad_api.replicas | default(2) }}

    # Spread across different nodes for availability (production only)
    constraint {
      distinct_hosts = true
    }
    {% endif %}

    # Rolling update configuration
    update {
      max_parallel = 1
      min_healthy_time = "5s"    # Reduced from 10s since API starts quickly
      healthy_deadline = "10m"    # Increased from 5m for initial health checks
      progress_deadline = "15m"   # Increased from 10m to allow more time
      auto_revert = true
      canary = 1
      auto_promote = true         # Enable automatic promotion of canaries for unattended rollouts
      health_check = "checks"     # Gate on service/Consul health checks
    }

    # Network configuration (moved from task level to group level)
    network {
      port "http" {}  # Dynamic port allocation
    }

    # Restart policy
    restart {
      attempts = 3
      interval = "10m"
      delay = "30s"
      mode = "fail"
    }

    task "api" {
      driver = "raw_exec"

      # Binary distribution via artifact download from SeaweedFS
      artifact {
        source = "http://{{ seaweedfs.filer_domain }}:{{ seaweedfs.filer_port }}/artifacts/api-binaries/{{ api_version }}/linux/amd64/api"
        destination = "local/api"
        mode = "file"
      }

      # Configuration for raw_exec driver
      config {
        command = "/bin/bash"
        args = ["local/start-api.sh"]
      }


      # Resource allocation
      resources {
        cpu = {{ nomad_api.resources.cpu | default(500) }}
        memory = {{ nomad_api.resources.memory | default(512) }}
      }

      # Environment configuration
      env {
        # API configuration - using dynamic port
        PORT = "${NOMAD_PORT_http}"
        # Controller URL uses full platform domain; do not prepend environment here
        PLOY_CONTROLLER = "https://api.{{ ploy.platform_domain }}/v1"
        PLOY_STORAGE_CONFIG = "/etc/ploy/storage/config.yaml"
        
        # HashiCorp service addresses
        CONSUL_ADDR = "http://127.0.0.1:8500"
        NOMAD_ADDR = "http://nomad.control.ploy.local:4646"
        NOMAD_DC = "{{ ploy.nomad_dc }}"
        # Nomad SDK resilience (used by API when talking to Nomad directly)
        NOMAD_HTTP_MAX_RETRIES = "{{ ploy.nomad_http_max_retries | default('5') }}"
        NOMAD_HTTP_BASE_DELAY = "{{ ploy.nomad_http_base_delay | default('500ms') }}"
        NOMAD_HTTP_MAX_DELAY = "{{ ploy.nomad_http_max_delay | default('30s') }}"
        NOMAD_SUBMIT_MAX_CONCURRENCY = "{{ ploy.nomad_submit_max_concurrency | default('4') }}"
        NOMAD_BLOCKING_WAIT = "{{ ploy.nomad_blocking_wait | default('30s') }}"

        # Force SDK mode for Nomad submissions (disable wrapper inside API process)
        USE_NOMAD_JOB_MANAGER = 0

        # SeaweedFS configuration. Use external DNS name so job containers resolve consistently.
        SEAWEEDFS_MASTER = "http://{{ seaweedfs.master_domain }}:{{ seaweedfs.master_port }}"
        SEAWEEDFS_FILER = "http://{{ seaweedfs.filer_domain }}:{{ seaweedfs.filer_port }}"
        PLOY_SEAWEEDFS_URL = "http://{{ seaweedfs.filer_domain }}:{{ seaweedfs.filer_port }}"
        SEAWEEDFS_URL = "http://{{ seaweedfs.filer_domain }}:{{ seaweedfs.filer_port }}"

        # OpenRewrite configuration for transformations
        JAVA_HOME = "/usr/lib/jvm/java-17-openjdk-amd64"

        # Mods job image overrides (server-side) — managed by inventory
        MODS_ORW_APPLY_IMAGE = "{{ ploy.mods.orw_apply_image }}"
        MODS_PLANNER_IMAGE = "{{ ploy.mods.planner_image }}"
        MODS_REDUCER_IMAGE = "{{ ploy.mods.reducer_image }}"
        MODS_LLM_EXEC_IMAGE = "{{ ploy.mods.llm_exec_image }}"
        MODS_REGISTRY = "{{ ploy.mods.registry }}"
                
        # Internal ARF Recipes Indexer
        PLOY_SECURITY_REGISTRY = "{{ ploy.security_registry | default('https://repo1.maven.org/maven2') }}"
        PLOY_SECURITY_MAVEN_GROUP = "{{ ploy.security_maven_group | default('org.openrewrite') }}"
        PLOY_SECURITY_DEFAULT_PACKS = "{{ ploy.security_default_packs | default('') }}"

        # LLM API Configuration (override via environment/secret store)
        LLM_PROVIDER = "{{ llm_provider | default('openai') }}"
        LLM_MODEL = "{{ llm_model | default('gpt-4') }}"
        LLM_API_KEY = "{{ lookup('env', 'LLM_API_KEY') | default('') }}"
        LLM_MAX_TOKENS = "{{ llm_max_tokens | default('2048') }}"
        LLM_TEMPERATURE = "{{ llm_temperature | default('0.1') }}"

        # Platform wildcard certificate configuration
        # Use fully qualified apps domain from vars/env (e.g., dev.ployd.app)
        PLOY_APPS_DOMAIN = "{{ ploy.apps_domain }}"
        # Use fully qualified platform domain from vars/env (e.g., dev.ployman.app)
        PLOY_PLATFORM_DOMAIN = "{{ ploy.platform_domain }}"
        PLOY_APPS_DOMAIN_PROVIDER = "{{ ploy.apps_domain_provider }}"
        
        # Development environment specifics (values derived from full domains)
        {% if ploy_environment is defined and ploy_environment == 'dev' %}
        PLOY_DEV_SUBDOMAIN = "dev"
        PLOY_DEV_APPS_DOMAIN = "{{ ploy.apps_domain }}"
        PLOY_WILDCARD_DOMAIN = "*.{{ ploy.apps_domain }}"
        # API/domain under platform domain (e.g., api.dev.ployman.app)
        PLOY_API_DOMAIN = "api.{{ ploy.platform_domain }}"
        PLOY_ENVIRONMENT = "dev"
        {% endif %}
        
        # DNS provider credentials (override via environment or secrets manager)
        {% if ploy.apps_domain_provider == 'namecheap' %}
        NAMECHEAP_API_USER = "{{ namecheap_api_user_default | default('') }}"
        NAMECHEAP_API_KEY = "{{ namecheap_api_key_default | default('') }}"
        {% elif ploy.apps_domain_provider == 'cloudflare' %}
        CLOUDFLARE_API_TOKEN = "{{ lookup('env', 'CLOUDFLARE_API_TOKEN') | default('') }}"
        {% endif %}
        
        # GitHub credentials for repository access
        GITHUB_PLOY_DEV_USERNAME = "{{ lookup('env', 'GITHUB_PLOY_DEV_USERNAME') }}"
        GITHUB_PLOY_DEV_PAT = "{{ lookup('env', 'GITHUB_PLOY_DEV_PAT') }}"

        GIT_AUTHOR_NAME = "{{ ploy.git_author_name }}"
        GIT_AUTHOR_EMAIL = "{{ ploy.git_author_email }}"
        GIT_COMMITTER_NAME = "{{ ploy.git_committer_name }}"
        GIT_COMMITTER_EMAIL = "{{ ploy.git_committer_email }}"

        # Deployment metadata
        PLOY_DEPLOYMENT_METHOD = "nomad"
        PLOY_NODE_ID = "${node.unique.name}"

        # GitLab integration (populated from local env via Ansible)
        GITLAB_TOKEN = "{{ ploy.gitlab_token }}"
        GITLAB_URL   = "{{ ploy.gitlab_url }}"
        MODS_SKIP_DEPLOY_LANES = "{{ ploy.mods.skip_deploy_lanes }}"

        # JetStream configuration for self-update work queue
        PLOY_JETSTREAM_URL = "nats://nats.ploy.local:4223"
        PLOY_UPDATES_JETSTREAM_ENABLED = "true"
        PLOY_UPDATES_JETSTREAM_URL = "nats://nats.ploy.local:4223"
        PLOY_UPDATES_STREAM = "updates_control_plane"
        PLOY_UPDATES_STATUS_STREAM = "updates_control_plane_status"
        PLOY_UPDATES_STREAM_SUBJECT = "updates.control-plane.tasks"
        PLOY_UPDATES_STATUS_SUBJECT = "updates.control-plane.status"
      }

      # Make binary executable and start
      template {
        data = <<EOF
#!/bin/bash
set -e

# Install required system dependencies in container
echo "[SETUP] Verifying system dependencies..."

# Verify git (pre-installed by Ansible)
if command -v git &> /dev/null; then
echo "[SETUP] OK git: $(git --version)"
else
  echo "[SETUP] WARN git: NOT AVAILABLE - ARF transformations may fail"
fi

# Verify Java (pre-installed by Ansible)
if command -v java &> /dev/null; then
  echo "[SETUP] OK java: $(java -version 2>&1 | head -n1)"
else
  echo "[SETUP] WARN java: NOT AVAILABLE - OpenRewrite operations may fail"  
fi

# Verify curl (pre-installed)
if command -v curl &> /dev/null; then
  echo "[SETUP] OK curl: $(curl --version | head -n1)"
else
  echo "[SETUP] WARN curl: NOT AVAILABLE - HTTP operations may fail"
fi

echo "[SETUP] Dependency verification completed"

# Make binary executable
chmod +x local/api

# Network diagnostics: best-effort GitLab reachability (escape HCL template markers)
GITLAB_URL=$${GITLAB_URL:-https://gitlab.com}
echo "[SETUP] Probing GitLab connectivity: $${GITLAB_URL}/api/v4/version"
set +e
GL_PROBE=$(curl -sS -o /dev/null -w "HTTP:%%{http_code} TIME:%%{time_total}" --connect-timeout 5 --max-time 10 "$${GITLAB_URL}/api/v4/version")
echo "[SETUP] GitLab probe result: ${GL_PROBE}"
set -e

# Attempt to load credentials if not provided via Nomad env
if [ -z "$GITLAB_TOKEN" ] && [ -r /home/ploy/.gitlab_token ]; then
  export GITLAB_TOKEN="$(tr -d '\n' </home/ploy/.gitlab_token 2>/dev/null)"
fi

echo "[SETUP] Starting Ploy API..."
exec local/api
EOF
        destination = "local/start-api.sh"
        perms = "755"
      }

      # Health checks
      service {
        name = "ploy-api"
        port = "http"
        tags = [
          "api",
          "ploy-api",
          "traefik.enable=true",
          "traefik.http.routers.ploy-api.rule=Host(`api.{{ ploy.platform_domain }}`)",
          "traefik.http.routers.ploy-api.tls=true",
          # Alias on apps domain (dev) so both domains work
          "traefik.http.routers.ploy-api-apps.rule=Host(`api.{{ ploy.apps_domain }}`)",
          "traefik.http.routers.ploy-api-apps.tls=true",
          "traefik.http.routers.ploy-api.tls.certresolver=default-acme",
          "traefik.http.routers.ploy-api-apps.tls.certresolver=default-acme",
        ]

        # Health check endpoint - simplified configuration
        check {
          type = "http"
          path = "/live"
          interval = "30s"
          timeout = "20s"
          port = "http"
        }

        # Readiness check
        check {
          name = "readiness"
          type = "http"
          path = "/ready"
          interval = "30s"
          timeout = "20s"
          port = "http"
        }

        # Versioned health check to align with external routing
        check {
          name = "versioned-health"
          type = "http"
          path = "/v1/health"
          interval = "30s"
          timeout = "20s"
          port = "http"
        }
        
        # Configure Consul to automatically deregister failed services
        meta {
          deregister_critical_service_after = "30s"
        }
      }

      # Graceful shutdown
      kill_timeout = "30s"
      kill_signal = "SIGTERM"

      # Logging configuration
      logs {
        max_files = 10
        max_file_size = 10
      }
    }
  }
}
