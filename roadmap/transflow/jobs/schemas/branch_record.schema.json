{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/transflow/branch_record.schema.json",
  "title": "Transflow Branch Record",
  "type": "object",
  "required": ["id", "status"],
  "properties": {
    "id": { "type": "string" },
    "status": { "enum": ["success", "failed", "canceled", "timeout"] },
    "artifact": { "type": "string" },
    "notes": { "type": "string" },
    "job_name": { "type": "string" },
    "job_id": { "type": "string" },
    "started_at": { "type": "string", "format": "date-time" },
    "finished_at": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}

