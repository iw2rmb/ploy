# Ploy Storage Configuration for SeaweedFS
# Simplified configuration with SeaweedFS as the only storage backend

# SeaweedFS master server address
master: "{{ seaweedfs.master_endpoint }}"

# SeaweedFS filer server address  
filer: "{{ seaweedfs.filer_endpoint }}"

# Collection name for storing artifacts
collection: "{{ seaweedfs.collections.artifacts.name }}"

# Replication strategy
replication: "{{ seaweedfs.collections.artifacts.replication }}"

# Request timeout in seconds
timeout: 30

# Data center identifier
datacenter: "dc1"

# Rack identifier
rack: "rack1"

# Collection organization for different artifact types
collections:
  artifacts: "{{ seaweedfs.collections.artifacts.name }}"
  metadata: "{{ seaweedfs.collections.metadata.name }}"
  debug: "{{ seaweedfs.collections.debug.name }}"
