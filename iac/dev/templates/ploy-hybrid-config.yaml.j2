# Ploy Hybrid Storage Configuration
# This configuration enables hybrid storage with SeaweedFS as primary
# and MinIO as secondary for gradual migration

provider: hybrid
endpoint: http://localhost:{{ seaweedfs.filer_port }}
bucket: {{ seaweedfs.collections.artifacts.name }}
region: dc1

# Hybrid storage configuration
hybrid:
  enabled: true
  primary_provider: "seaweedfs"
  dual_write: true        # Write to both SeaweedFS and MinIO
  fallback_read: true     # Fall back to MinIO if SeaweedFS read fails

# SeaweedFS configuration (primary)
seaweedfs:
  master: "localhost:{{ seaweedfs.master_port }}"
  filer: "localhost:{{ seaweedfs.filer_port }}"
  collection: "{{ seaweedfs.collections.artifacts.name }}"
  replication: "{{ seaweedfs.collections.artifacts.replication }}"
  timeout: 30

# MinIO configuration (secondary)
access_key: "{{ minio.access_key }}"
secret_key: "{{ minio.secret_key }}"
path_style: true
tls_insecure_skip_verify: true

# Collection organization
buckets:
  artifacts: "{{ seaweedfs.collections.artifacts.name }}"
  logs: "{{ seaweedfs.collections.debug.name }}"
  cache: "{{ seaweedfs.collections.debug.name }}"