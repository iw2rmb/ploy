{
  "agents": {
    "ploy-lane-analyzer": {
      "description": "Analyze application structure and recommend optimal Ploy deployment lanes",
      "tools": ["Read", "Glob", "Grep"],
      "triggers": [
        "lane detection",
        "lane selection", 
        "deployment optimization",
        "performance tuning",
        "footprint analysis"
      ],
      "expertise": [
        "Unikraft unikernel analysis",
        "JVM/.NET framework detection",
        "Container vs VM optimization",
        "WASM compilation detection"
      ]
    },
    "ploy-infrastructure-manager": {
      "description": "Handle Ploy infrastructure deployment, VPS management, and Nomad operations", 
      "tools": ["Bash", "Read", "Edit", "Glob"],
      "triggers": [
        "VPS deployment",
        "Nomad job management",
        "infrastructure setup",
        "Ansible playbook",
        "deployment automation"
      ],
      "expertise": [
        "Nomad cluster management",
        "Consul/Vault integration", 
        "FreeBSD jail configuration",
        "SeaweedFS storage setup"
      ]
    },
    "ploy-api-developer": {
      "description": "Develop and maintain Ploy REST API endpoints and controller logic",
      "tools": ["Read", "Edit", "MultiEdit", "Grep", "Bash"],
      "triggers": [
        "API endpoint",
        "REST API",
        "controller logic",
        "HTTP handlers",
        "API documentation"
      ],
      "expertise": [
        "Go Fiber framework",
        "RESTful API design",
        "API versioning",
        "Request/response handling"
      ]
    },
    "ploy-cli-developer": {
      "description": "Build and enhance Ploy CLI commands and user experience",
      "tools": ["Read", "Edit", "MultiEdit", "Bash"],
      "triggers": [
        "CLI command",
        "command line",
        "user interface",
        "CLI enhancement",
        "command parsing"
      ],
      "expertise": [
        "Go CLI frameworks",
        "Command structure design",
        "User experience optimization",
        "Help text and documentation"
      ]
    },
    "ploy-certificate-specialist": {
      "description": "Handle certificate management, ACME integration, and SSL/TLS operations",
      "tools": ["Read", "Edit", "Bash", "Grep"],
      "triggers": [
        "certificate",
        "SSL",
        "TLS", 
        "ACME",
        "Let's Encrypt",
        "domain certificate"
      ],
      "expertise": [
        "ACME protocol implementation",
        "Certificate lifecycle management",
        "DNS challenge validation",
        "Certificate storage and renewal"
      ]
    },
    "ploy-testing-coordinator": {
      "description": "Execute comprehensive testing workflows following MUP requirements",
      "tools": ["Bash", "Read", "Edit", "Task"],
      "triggers": [
        "test execution",
        "VPS testing",
        "MUP compliance",
        "test automation",
        "integration testing"
      ],
      "expertise": [
        "Test scenario execution",
        "VPS environment management", 
        "Automated deployment testing",
        "Error diagnosis and reporting"
      ]
    },
    "ploy-storage-architect": {
      "description": "Design and implement storage solutions using SeaweedFS and distributed systems",
      "tools": ["Read", "Edit", "Bash", "Grep"],
      "triggers": [
        "storage",
        "SeaweedFS",
        "distributed storage",
        "file management",
        "storage config"
      ],
      "expertise": [
        "SeaweedFS configuration",
        "Distributed file systems",
        "Storage abstraction layers",
        "Data persistence strategies"
      ]
    },
    "ploy-security-auditor": {
      "description": "Review security implementations, certificate management, and access controls",
      "tools": ["Read", "Grep", "Bash"],
      "triggers": [
        "security review",
        "vulnerability",
        "access control",
        "security audit",
        "permission check"
      ],
      "expertise": [
        "Security best practices",
        "Certificate security",
        "Access control patterns",
        "Vulnerability assessment"
      ]
    }
  },
  "selection_rules": {
    "priority_keywords": {
      "lane": "ploy-lane-analyzer",
      "certificate": "ploy-certificate-specialist", 
      "API": "ploy-api-developer",
      "CLI": "ploy-cli-developer",
      "VPS": "ploy-infrastructure-manager",
      "test": "ploy-testing-coordinator",
      "storage": "ploy-storage-architect",
      "security": "ploy-security-auditor"
    },
    "context_patterns": {
      "deployment_and_infrastructure": "ploy-infrastructure-manager",
      "api_and_controllers": "ploy-api-developer", 
      "user_interface": "ploy-cli-developer",
      "performance_analysis": "ploy-lane-analyzer",
      "certificate_operations": "ploy-certificate-specialist",
      "testing_workflows": "ploy-testing-coordinator"
    },
    "file_patterns": {
      "api/": "ploy-api-developer",
      "internal/cli/": "ploy-cli-developer",
      "tools/lane-pick/": "ploy-lane-analyzer",
      "tests/": "ploy-testing-coordinator",
      "iac/": "ploy-infrastructure-manager",
      "internal/storage/": "ploy-storage-architect",
      "api/acme/": "ploy-certificate-specialist"
    }
  },
  "auto_selection": {
    "enabled": true,
    "confidence_threshold": 0.7,
    "fallback_agent": "general-purpose"
  }
}