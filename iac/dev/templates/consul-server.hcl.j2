datacenter = "dc1"
data_dir = "/opt/hashicorp/consul"
log_level = "INFO"
node_name = "consul-server"
server = true
bootstrap_expect = 1

bind_addr = "0.0.0.0"
client_addr = "0.0.0.0"

ports {
  grpc = 8502
}

connect {
  enabled = true
}

ui_config {
  enabled = true
}

acl = {
  enabled = false
  default_policy = "allow"
}