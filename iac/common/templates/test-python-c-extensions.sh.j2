#!/bin/bash
# Test script for Python C-extension detection in lane picker

set -e

echo "=== Python C-Extension Detection Testing ==="

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Helper functions
log_info() {
    echo -e "${YELLOW}[INFO]${NC} $1"
}

log_success() {
    echo -e "${GREEN}[SUCCESS]${NC} $1"
}

log_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

test_lane_detection() {
    local test_name="$1"
    local app_path="$2"
    local expected_lane="$3"
    local expected_language="$4"
    local reason_contains="$5"
    
    log_info "Testing: $test_name"
    
    result=$(cd /home/ploy/ploy && ./lane-pick --path "$app_path" 2>/dev/null)
    
    if [ $? -ne 0 ]; then
        log_error "$test_name - Lane picker execution failed"
        return 1
    fi
    
    lane=$(echo "$result" | jq -r '.lane')
    language=$(echo "$result" | jq -r '.language')
    reasons=$(echo "$result" | jq -r '.reasons | join(" ")')
    
    success=true
    
    if [ "$lane" != "$expected_lane" ]; then
        log_error "$test_name - Expected lane: $expected_lane, Got: $lane"
        success=false
    fi
    
    if [ "$language" != "$expected_language" ]; then
        log_error "$test_name - Expected language: $expected_language, Got: $language"
        success=false
    fi
    
    if [ -n "$reason_contains" ] && [[ ! "$reasons" == *"$reason_contains"* ]]; then
        log_error "$test_name - Expected reason to contain: '$reason_contains', Got: '$reasons'"
        success=false
    fi
    
    if [ "$success" = true ]; then
        log_success "$test_name - Lane: $lane, Language: $language"
        echo "  Reasons: $reasons"
    else
        echo "  Full result: $result"
    fi
    
    echo
    return $([ "$success" = true ] && echo 0 || echo 1)
}

# Build lane picker if not exists
cd /home/ploy/ploy
if [ ! -f "./lane-pick" ]; then
    log_info "Building lane picker..."
    go build -o lane-pick ./tools/lane-pick
fi

# Test existing Python app (baseline - should be Lane B)
test_lane_detection \
    "Pure Python project (baseline)" \
    "/home/ploy/ploy/apps/python-apisvc" \
    "B" \
    "python" \
    "python detected"

# Create test projects for C-extension scenarios
TEST_DIR="/tmp/ploy-python-tests"
rm -rf "$TEST_DIR"
mkdir -p "$TEST_DIR"

# Test 1: Python project with C source files
log_info "Creating Python project with C source files..."
mkdir -p "$TEST_DIR/python-c-source"
cat > "$TEST_DIR/python-c-source/pyproject.toml" << 'EOF'
[build-system]
requires = ["setuptools", "wheel"]
build-backend = "setuptools.build_meta"

[project]
name = "c-extension-test"
version = "0.1.0"
EOF

cat > "$TEST_DIR/python-c-source/fastmath.c" << 'EOF'
#include <Python.h>

static PyObject* add(PyObject* self, PyObject* args) {
    int a, b;
    if (!PyArg_ParseTuple(args, "ii", &a, &b))
        return NULL;
    return PyLong_FromLong(a + b);
}

static PyMethodDef methods[] = {
    {"add", add, METH_VARARGS, "Add two integers"},
    {NULL, NULL, 0, NULL}
};

static struct PyModuleDef module = {
    PyModuleDef_HEAD_INIT, "fastmath", NULL, -1, methods
};

PyMODINIT_FUNC PyInit_fastmath(void) {
    return PyModule_Create(&module);
}
EOF

test_lane_detection \
    "Python project with C source files" \
    "$TEST_DIR/python-c-source" \
    "C" \
    "python" \
    "C-extensions detected"

# Test 2: Python project with Cython files
log_info "Creating Python project with Cython files..."
mkdir -p "$TEST_DIR/python-cython"
cat > "$TEST_DIR/python-cython/pyproject.toml" << 'EOF'
[build-system]
requires = ["setuptools", "Cython"]
build-backend = "setuptools.build_meta"
EOF

cat > "$TEST_DIR/python-cython/math_utils.pyx" << 'EOF'
def fibonacci(int n):
    cdef int a = 0
    cdef int b = 1
    cdef int i
    
    if n <= 1:
        return n
    
    for i in range(2, n + 1):
        a, b = b, a + b
    return b
EOF

cat > "$TEST_DIR/python-cython/setup.py" << 'EOF'
from setuptools import setup
from Cython.Build import cythonize

setup(
    ext_modules = cythonize("math_utils.pyx")
)
EOF

test_lane_detection \
    "Python project with Cython files" \
    "$TEST_DIR/python-cython" \
    "C" \
    "python" \
    "C-extensions detected"

# Test 3: Python project with numpy dependency
log_info "Creating Python project with numpy dependency..."
mkdir -p "$TEST_DIR/python-numpy"
cat > "$TEST_DIR/python-numpy/pyproject.toml" << 'EOF'
[project]
name = "numpy-test"
dependencies = ["numpy>=1.20.0"]
EOF

test_lane_detection \
    "Python project with numpy dependency" \
    "$TEST_DIR/python-numpy" \
    "C" \
    "python" \
    "C-extensions detected"

# Test 4: Python project with scipy dependency
log_info "Creating Python project with scipy and pandas..."
mkdir -p "$TEST_DIR/python-scientific"
cat > "$TEST_DIR/python-scientific/requirements.txt" << 'EOF'
scipy>=1.7.0
pandas>=1.3.0
matplotlib>=3.4.0
EOF

test_lane_detection \
    "Python project with scientific libraries" \
    "$TEST_DIR/python-scientific" \
    "C" \
    "python" \
    "C-extensions detected"

# Test 5: Python project with setuptools extensions
log_info "Creating Python project with setuptools extensions..."
mkdir -p "$TEST_DIR/python-setuptools"
cat > "$TEST_DIR/python-setuptools/setup.py" << 'EOF'
from setuptools import setup, Extension

module = Extension('mymodule',
                   sources = ['mymodule.c'],
                   include_dirs = ['/usr/local/include'],
                   libraries = ['math'],
                   library_dirs = ['/usr/local/lib'])

setup(name = 'MyPackage',
      version = '1.0',
      description = 'C extension package',
      ext_modules = [module])
EOF

test_lane_detection \
    "Python project with setuptools extensions" \
    "$TEST_DIR/python-setuptools" \
    "C" \
    "python" \
    "C-extensions detected"

# Test 6: Python project with cryptography dependency
log_info "Creating Python project with cryptography..."
mkdir -p "$TEST_DIR/python-crypto"
cat > "$TEST_DIR/python-crypto/requirements.txt" << 'EOF'
cryptography>=3.4.0
psycopg2-binary>=2.8.0
lxml>=4.6.0
EOF

test_lane_detection \
    "Python project with cryptography libraries" \
    "$TEST_DIR/python-crypto" \
    "C" \
    "python" \
    "C-extensions detected"

# Test 7: Python project with CMake and pybind11
log_info "Creating Python project with CMake and pybind11..."
mkdir -p "$TEST_DIR/python-cmake"
cat > "$TEST_DIR/python-cmake/CMakeLists.txt" << 'EOF'
cmake_minimum_required(VERSION 3.12)
project(pybind11_example)

find_package(pybind11 REQUIRED)

pybind11_add_module(example example.cpp)
EOF

cat > "$TEST_DIR/python-cmake/pyproject.toml" << 'EOF'
[project]
name = "cmake-example"
EOF

test_lane_detection \
    "Python project with CMake and pybind11" \
    "$TEST_DIR/python-cmake" \
    "C" \
    "python" \
    "C-extensions detected"

# Test 8: Python project with Cython imports
log_info "Creating Python project with Cython imports..."
mkdir -p "$TEST_DIR/python-cython-import"
cat > "$TEST_DIR/python-cython-import/main.py" << 'EOF'
from Cython.Build import cythonize
import numpy as np
from setuptools import setup

def build_extensions():
    return cythonize("*.pyx")
EOF

cat > "$TEST_DIR/python-cython-import/pyproject.toml" << 'EOF'
[project]
name = "cython-import-test"
EOF

test_lane_detection \
    "Python project with Cython imports" \
    "$TEST_DIR/python-cython-import" \
    "C" \
    "python" \
    "C-extensions detected"

# Test 9: Python project with build configuration hints
log_info "Creating Python project with build configuration..."
mkdir -p "$TEST_DIR/python-build-config"
cat > "$TEST_DIR/python-build-config/setup.py" << 'EOF'
from setuptools import setup

setup(
    name='build-test',
    version='1.0',
    cmdclass={'build_ext': CustomBuildExt},
    include_dirs=['./include'],
    library_dirs=['/usr/local/lib'],
    libraries=['custom']
)
EOF

test_lane_detection \
    "Python project with build configuration" \
    "$TEST_DIR/python-build-config" \
    "C" \
    "python" \
    "C-extensions detected"

# Test 10: Python project with C++ extensions
log_info "Creating Python project with C++ extensions..."
mkdir -p "$TEST_DIR/python-cpp"
cat > "$TEST_DIR/python-cpp/pyproject.toml" << 'EOF'
[project]
name = "cpp-extension"
EOF

cat > "$TEST_DIR/python-cpp/wrapper.cpp" << 'EOF'
#include <pybind11/pybind11.h>

int add(int i, int j) {
    return i + j;
}

PYBIND11_MODULE(example, m) {
    m.def("add", &add, "A function which adds two numbers");
}
EOF

test_lane_detection \
    "Python project with C++ extensions" \
    "$TEST_DIR/python-cpp" \
    "C" \
    "python" \
    "C-extensions detected"

# Test 11: Pure Python project (should remain Lane B)
log_info "Creating pure Python project..."
mkdir -p "$TEST_DIR/python-pure"
cat > "$TEST_DIR/python-pure/pyproject.toml" << 'EOF'
[project]
name = "pure-python"
dependencies = ["requests", "click", "rich"]
EOF

cat > "$TEST_DIR/python-pure/main.py" << 'EOF'
import requests
import click

@click.command()
def hello():
    response = requests.get("https://httpbin.org/json")
    print(f"Response: {response.json()}")

if __name__ == "__main__":
    hello()
EOF

test_lane_detection \
    "Pure Python project (no C-extensions)" \
    "$TEST_DIR/python-pure" \
    "B" \
    "python" \
    "python detected"

# Test 12: Python project with .pxd Cython definition files
log_info "Creating Python project with Cython definition files..."
mkdir -p "$TEST_DIR/python-pxd"
cat > "$TEST_DIR/python-pxd/math_defs.pxd" << 'EOF'
cdef class FastMath:
    cdef int value
    cdef int calculate(self, int x)
EOF

cat > "$TEST_DIR/python-pxd/pyproject.toml" << 'EOF'
[project]
name = "pxd-test"
EOF

test_lane_detection \
    "Python project with Cython .pxd files" \
    "$TEST_DIR/python-pxd" \
    "C" \
    "python" \
    "C-extensions detected"

# Cleanup
rm -rf "$TEST_DIR"

echo
echo "=== Python C-Extension Detection Test Summary ==="
log_success "All Python C-extension detection scenarios tested successfully!"
echo
echo "✅ C source files (.c, .cc, .cpp, .cxx) → Lane C"
echo "✅ Cython files (.pyx, .pxd) → Lane C"
echo "✅ Scientific libraries (numpy, scipy, pandas) → Lane C"
echo "✅ Cryptography libraries (cryptography, psycopg2, lxml) → Lane C"
echo "✅ Setuptools extensions (ext_modules, Extension) → Lane C"
echo "✅ Build configuration (build_ext, include_dirs) → Lane C"
echo "✅ CMake + pybind11 integration → Lane C"
echo "✅ Cython imports and usage → Lane C"
echo "✅ Pure Python projects → Lane B (unaffected)"
echo "✅ Enhanced file search covers Python build files"
echo "✅ Comprehensive C-extension detection working"