#!/bin/bash
# API Update Script
# Updates Ploy API via unified deployment system using ployman

set -e

PLOY_DIR="/home/ploy/ploy"
CONTROLLER_SCRIPTS_DIR="/home/ploy/controller-scripts"

echo "=== Ploy API Update via Unified Deployment System ==="

# Check if we're in the right directory
if [[ ! -d "$PLOY_DIR" ]]; then
    echo "Error: Ploy directory not found at $PLOY_DIR"
    exit 1
fi

cd "$PLOY_DIR"

# Check if ployman CLI is available
if [[ ! -x "./bin/ployman" ]]; then
    echo "Building ployman CLI..."
    go build -o bin/ployman ./cmd/ployman
    
    if [[ ! -x "./bin/ployman" ]]; then
        echo "Error: Failed to build ployman CLI"
        exit 1
    fi
fi

# Generate new version identifier
NEW_VERSION="$(date +%Y%m%d-%H%M%S)-$(git rev-parse --short HEAD)"
echo "Deployment version: $NEW_VERSION"

# Get current version for rollback reference
CURRENT_VERSION=$(cat /opt/ploy/current-api-version 2>/dev/null || echo "unknown")
echo "Current version: $CURRENT_VERSION"

# Build API binary
echo "Building API binary..."
go build -o bin/api ./api

# Verify binary was created
if [[ ! -x "./bin/api" ]]; then
    echo "Error: Failed to build API binary"
    exit 1
fi

# Use unified deployment system via ployman
echo "Deploying via unified deployment system..."
export PLOY_CONTROLLER="${PLOY_CONTROLLER:-https://api.dev.ployman.app/v1}"

# Deploy using ployman push
if ./bin/ployman push -a ploy-api; then
    echo "✅ Deployment initiated successfully via ployman"
else
    echo "❌ Deployment failed via ployman"
    echo "Attempting fallback bootstrap deployment..."
    
    # Fallback: direct bootstrap deployment
    cp bin/api /tmp/ploy-api-bootstrap
    chmod +x /tmp/ploy-api-bootstrap
    
    # Use existing bootstrap job
    export NOMAD_ADDR="http://localhost:4646"
    if nomad job run /opt/hashicorp/nomad/jobs/ploy-api-bootstrap.hcl; then
        echo "✅ Fallback bootstrap deployment successful"
    else
        echo "❌ Fallback deployment also failed"
        exit 1
    fi
fi

# Monitor deployment progress
echo "Monitoring deployment progress..."
TIMEOUT=300  # 5 minutes
START_TIME=$(date +%s)

while true; do
    CURRENT_TIME=$(date +%s)
    if (( CURRENT_TIME - START_TIME > TIMEOUT )); then
        echo "Error: Deployment timeout after 5 minutes"
        echo "Rolling back to previous version..."
        "$CONTROLLER_SCRIPTS_DIR/rollback-api.sh" "$CURRENT_VERSION"
        exit 1
    fi

    # Check allocation status
    if ALLOCS=$(/opt/hashicorp/bin/nomad-job-manager.sh allocs --job ploy-api --format json 2>/dev/null); then
        RUNNING_COUNT=$(echo "$ALLOCS" | jq -r '.[].ClientStatus' | grep -c "running" || echo "0")
        TOTAL_COUNT=$(echo "$ALLOCS" | jq '. | length')

        echo "Allocation status: $RUNNING_COUNT/$TOTAL_COUNT running"

        if [[ "$RUNNING_COUNT" == "$TOTAL_COUNT" ]] && [[ "$RUNNING_COUNT" -gt "0" ]]; then
            echo "All allocations are running!"
            break
        fi
    else
        echo "Waiting for job allocations..."
    fi

    sleep 10
done

# Verify health via multiple endpoints
echo "Verifying API health..."
sleep 30  # Allow time for startup

HEALTH_ENDPOINTS=(
    "https://api.dev.ployman.app/health"
)

SUCCESS_COUNT=0
for endpoint in "${HEALTH_ENDPOINTS[@]}"; do
    if curl -f -s "$endpoint" > /dev/null 2>&1; then
        echo "✅ Health check passed: $endpoint"
        SUCCESS_COUNT=$((SUCCESS_COUNT + 1))
    else
        echo "⚠️  Health check failed: $endpoint"
    fi
done

if [[ "$SUCCESS_COUNT" -eq 0 ]]; then
    echo "❌ All health checks failed - rolling back"
    "$CONTROLLER_SCRIPTS_DIR/rollback-api.sh" "$CURRENT_VERSION"
    exit 1
elif [[ "$SUCCESS_COUNT" -lt 2 ]]; then
    echo "⚠️  Partial health check success - deployment may need attention"
else
    echo "✅ All health checks passed"
fi

# Save current version
echo "$NEW_VERSION" | sudo tee /opt/ploy/current-api-version > /dev/null

# Update deployment method marker
echo "unified-deployment-active" | sudo tee /opt/ploy/deployment-method > /dev/null

echo "✅ API updated successfully to version $NEW_VERSION"
echo "API endpoints:"
echo "  - Health: https://api.dev.ployman.app/health"
echo "  - External: https://api.dev.ployman.app/health"
echo "  - API version: https://api.dev.ployman.app/v1/version"
