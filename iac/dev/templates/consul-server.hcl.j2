datacenter = "dc1"
data_dir = "/opt/hashicorp/consul"
log_level = "INFO"
node_name = "consul-server"
server = true
bootstrap_expect = 1

# Bind to the primary network interface (auto-detected or specify manually)
bind_addr = "{{ ansible_default_ipv4.address | default('127.0.0.1') }}"
client_addr = "0.0.0.0"
advertise_addr = "{{ ansible_default_ipv4.address | default('127.0.0.1') }}"

ports {
  grpc = 8502
}

connect {
  enabled = true
}

ui_config {
  enabled = true
}

acl = {
  enabled = false
  default_policy = "allow"
}

# Performance and retry configurations
performance {
  raft_multiplier = 1
}

retry_join = ["{{ ansible_default_ipv4.address | default('127.0.0.1') }}"]