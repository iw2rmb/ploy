# Nomad Job Template for Lane G - WebAssembly Applications
# Generated by Ploy for wazero runtime deployment

job "wasm-{{ app_name }}" {
  datacenters = ["{{ datacenter | default('dc1') }}"]
  type = "service"
  
  constraint {
    attribute = "${attr.kernel.name}"
    value     = "linux"
  }

  # Ensure WASM runner is available
  constraint {
    attribute = "${attr.unique.hostname}"
    operator  = "regexp"
    value     = ".*"
  }

  group "wasm-runtime" {
    count = {{ replicas | default(1) }}
    
    restart {
      attempts = 3
      interval = "30m"
      delay    = "15s"
      mode     = "fail"
    }

    # WASM-specific resource constraints - typically much smaller than containers
    resources {
      cpu    = {{ resources.cpu | default(200) }}    # MHz - WASM is CPU efficient
      memory = {{ resources.memory | default(64) }}   # MB - WASM has predictable memory usage
      
      # WASM modules are typically very small
      disk = {{ resources.disk | default(32) }}      # MB
    }

    # Network configuration for WASM applications
    network {
      mbits = {{ network.mbits | default(10) }}
      
      {% if port_mapping %}
      port "http" {
        static = {{ port_mapping.http }}
      }
      {% else %}
      port "http" {}
      {% endif %}
    }

    # WASM module artifact download
    artifact {
      source      = "{{ artifact_url }}"
      destination = "local/app.wasm"
      mode        = "file"
      
      # Verify WASM module integrity
      {% if artifact_checksum %}
      options {
        checksum = "sha256:{{ artifact_checksum }}"
      }
      {% endif %}
    }

    # Additional WASM runtime files if needed
    {% if wasm_runtime_files %}
    {% for file in wasm_runtime_files %}
    artifact {
      source      = "{{ file.url }}"
      destination = "local/{{ file.name }}"
      mode        = "file"
    }
    {% endfor %}
    {% endif %}

    task "wasm-runner" {
      driver = "exec"
      
      config {
        command = "/usr/local/bin/ploy-wasm-runner"
        args = [
          "--module", "local/app.wasm",
          "--port", "${NOMAD_PORT_http}",
          "--max-memory", "{{ wasm_config.max_memory_mb | default(32) }}MB",
          "--timeout", "{{ wasm_config.timeout | default(30) }}s",
          {% if environment_vars %}
          {% for key, value in environment_vars.items() %}
          "--env", "{{ key }}={{ value }}",
          {% endfor %}
          {% endif %}
        ]
      }

      # WASM runtime environment variables
      env {
        # Application metadata
        WASM_APP_NAME = "{{ app_name }}"
        WASM_RUNTIME  = "wazero"
        WASM_VERSION  = "1.5.0"
        
        # Runtime configuration
        WASM_MAX_MEMORY_MB = "{{ wasm_config.max_memory_mb | default(32) }}"
        WASM_MAX_EXEC_TIME = "{{ wasm_config.timeout | default(30) }}s"
        
        # Nomad integration
        NOMAD_ALLOC_ID = "${NOMAD_ALLOC_ID}"
        NOMAD_TASK_NAME = "${NOMAD_TASK_NAME}"
        
        {% if wasi_config %}
        # WASI configuration
        WASI_ROOT = "/tmp/wasi-${NOMAD_ALLOC_ID}"
        WASI_PREOPEN_DIRS = "{{ wasi_config.preopen_dirs | join(',') }}"
        {% endif %}
        
        {% if environment_vars %}
        # Application environment variables
        {% for key, value in environment_vars.items() %}
        {{ key }} = "{{ value }}"
        {% endfor %}
        {% endif %}
      }

      # WASM module validation and preparation
      template {
        data = <<-EOH
#!/bin/bash
set -euo pipefail

echo "Validating WASM module: local/app.wasm"

# Check WASM file exists and is not empty
if [ ! -f "local/app.wasm" ]; then
    echo "ERROR: WASM module not found"
    exit 1
fi

if [ ! -s "local/app.wasm" ]; then
    echo "ERROR: WASM module is empty"
    exit 1
fi

# Validate WASM magic bytes (0x00 0x61 0x73 0x6D)
if ! head -c 4 local/app.wasm | xxd | grep -q "0061 736d"; then
    echo "WARNING: WASM module may not have valid magic bytes"
fi

# Create WASI sandbox directory
WASI_ROOT="/tmp/wasi-${NOMAD_ALLOC_ID}"
mkdir -p "$WASI_ROOT"/{tmp,data}
chmod 755 "$WASI_ROOT"
chmod 1777 "$WASI_ROOT/tmp"

echo "WASM module validation completed successfully"
EOH
        destination = "local/validate-wasm.sh"
        perms = "755"
      }

      # Pre-start hook to validate WASM module
      lifecycle {
        hook = "prestart"
        sidecar = false
      }

      # Service registration for WASM applications
      service {
        name = "wasm-{{ app_name }}"
        port = "http"
        
        tags = [
          "wasm",
          "lane-g",
          "app:{{ app_name }}",
          "version:{{ version | default('latest') }}",
          "traefik.enable=true",
          "traefik.http.routers.{{ app_name }}.rule=Host(`{{ app_name }}.{{ domain | default('ployd.app') }}`)",
          "traefik.http.routers.{{ app_name }}.entrypoints=web",
          {% if ssl_enabled %}
          "traefik.http.routers.{{ app_name }}-secure.rule=Host(`{{ app_name }}.{{ domain | default('ployd.app') }}`)",
          "traefik.http.routers.{{ app_name }}-secure.entrypoints=websecure",
          "traefik.http.routers.{{ app_name }}-secure.tls=true",
          "traefik.http.routers.{{ app_name }}-secure.tls.certresolver=letsencrypt",
          {% endif %}
        ]

        # Health check for WASM application
        check {
          type     = "http"
          path     = "{{ health_check.path | default('/health') }}"
          interval = "{{ health_check.interval | default('10s') }}"
          timeout  = "{{ health_check.timeout | default('3s') }}"
          
          check_restart {
            limit = {{ health_check.restart_limit | default(3) }}
            grace = "{{ health_check.grace_period | default('10s') }}"
          }
        }

        # Additional health check for WASM runtime
        check {
          type     = "http"
          path     = "/wasm-health"
          interval = "30s"
          timeout  = "5s"
          
          check_restart {
            limit = 2
            grace = "5s"
          }
        }
      }

      # Resource limits specific to WASM runtime
      resources {
        cpu    = {{ resources.cpu | default(200) }}
        memory = {{ resources.memory | default(64) }}
        
        # WASM has predictable memory usage patterns
        memory_max = {{ resources.memory_max | default(128) }}
      }

      # Logging configuration for WASM applications
      logs {
        max_files     = {{ logs.max_files | default(5) }}
        max_file_size = {{ logs.max_file_size | default(10) }}
      }

      # Graceful shutdown for WASM applications
      kill_timeout = "{{ kill_timeout | default('10s') }}"
      kill_signal  = "SIGTERM"

      # Volume mounts for WASI filesystem access
      {% if wasi_config and wasi_config.volumes %}
      {% for volume in wasi_config.volumes %}
      volume_mount {
        volume      = "{{ volume.name }}"
        destination = "{{ volume.destination }}"
        read_only   = {{ volume.read_only | default(false) | lower }}
      }
      {% endfor %}
      {% endif %}
    }

    # WASI filesystem volumes
    {% if wasi_config and wasi_config.volumes %}
    {% for volume in wasi_config.volumes %}
    volume "{{ volume.name }}" {
      type   = "host"
      source = "{{ volume.source }}"
    }
    {% endfor %}
    {% endif %}

    # Ephemeral disk for WASM temporary files
    ephemeral_disk {
      size = {{ ephemeral_disk.size | default(128) }}
      sticky = {{ ephemeral_disk.sticky | default(false) | lower }}
      migrate = {{ ephemeral_disk.migrate | default(false) | lower }}
    }
  }

  # Update strategy for zero-downtime deployments
  update {
    max_parallel      = {{ update.max_parallel | default(1) }}
    min_healthy_time  = "{{ update.min_healthy_time | default('15s') }}"
    healthy_deadline  = "{{ update.healthy_deadline | default('5m') }}"
    progress_deadline = "{{ update.progress_deadline | default('10m') }}"
    
    {% if update.canary %}
    canary            = {{ update.canary }}
    auto_promote      = {{ update.auto_promote | default(false) | lower }}
    auto_revert       = {{ update.auto_revert | default(true) | lower }}
    {% endif %}
  }

  # Reschedule failed allocations
  reschedule {
    attempts  = {{ reschedule.attempts | default(3) }}
    interval  = "{{ reschedule.interval | default('5m') }}"
    delay     = "{{ reschedule.delay | default('30s') }}"
    unlimited = {{ reschedule.unlimited | default(false) | lower }}
  }
}