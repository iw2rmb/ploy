{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/iw2rmb/ploy/docs/schemas/integration_manifest.schema.json",
  "title": "Ploy Integration Manifest",
  "description": "Schema describing integration manifests that capture topology, fixtures, lanes, and Aster toggles for the workflow runner.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "name",
    "version",
    "summary",
    "topology",
    "fixtures",
    "lanes"
  ],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Manifest identifier (e.g. commit-app, smoke)."
    },
    "version": {
      "type": "string",
      "minLength": 1,
      "description": "Semantic or date-based version."
    },
    "summary": {
      "type": "string",
      "minLength": 1,
      "description": "Markdown summary explaining the manifest purpose and guidance."
    },
    "topology": {
      "type": "object",
      "additionalProperties": false,
      "required": ["description", "allow"],
      "properties": {
        "description": {
          "type": "string",
          "description": "Markdown description of the allowed topology."
        },
        "allow": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["from", "to"],
            "properties": {
              "from": {
                "type": "string",
                "minLength": 1
              },
              "to": {
                "type": "string",
                "minLength": 1
              },
              "reason": {
                "type": "string"
              }
            }
          }
        },
        "deny": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["from", "to", "reason"],
            "properties": {
              "from": {
                "type": "string",
                "minLength": 1
              },
              "to": {
                "type": "string",
                "minLength": 1
              },
              "reason": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    },
    "fixtures": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required"],
      "properties": {
        "required": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "reference"],
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "reference": {
                "type": "string",
                "minLength": 1
              },
              "reason": {
                "type": "string"
              }
            }
          }
        },
        "optional": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "reference"],
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "reference": {
                "type": "string",
                "minLength": 1
              },
              "reason": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    },
    "lanes": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required"],
      "properties": {
        "required": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "reason"],
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "reason": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "allowed": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name"],
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "reason": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "aster": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "required": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "optional": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      }
    }
  }
}
