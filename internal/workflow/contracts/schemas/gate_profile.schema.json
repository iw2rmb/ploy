{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Ploy Build Gate Profile",
  "description": "Schema for non-interactive gate profile outputs and persisted repo gate profiles. YAML is supported as a JSON superset.",
  "$comment": "Infra-healing candidate payloads must set targets.active and follow terminal unsupported markers when no runnable gate target remains.",
  "type": "object",
  "required": [
    "schema_version",
    "repo_id",
    "runner_mode",
    "stack",
    "targets",
    "orchestration",
    "tactics_used",
    "attempts",
    "evidence",
    "repro_check",
    "prompt_delta_suggestion"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "minimum": 1
    },
    "repo_id": {
      "type": "string",
      "minLength": 1
    },
    "runner_mode": {
      "type": "string",
      "enum": [
        "simple",
        "complex"
      ]
    },
    "stack": {
      "$ref": "#/definitions/stack"
    },
    "runtime": {
      "$ref": "#/definitions/runtimeHints"
    },
    "targets": {
      "$comment": "Gate runtime resolves command and env from the selected targets.active target.",
      "type": "object",
      "required": [
        "active",
        "build",
        "unit",
        "all_tests"
      ],
      "properties": {
        "active": {
          "$comment": "Recovery transitions should move forward (all_tests -> unit -> build -> unsupported). external_service_unreachable and registry_auth_failed are strong signals to move off all_tests, but they are not the only possible switch condition; unit-stage occurrences suggest refining unit selection before switching to build.",
          "type": "string",
          "enum": [
            "build",
            "unit",
            "all_tests",
            "unsupported"
          ]
        },
        "build": {
          "$ref": "#/definitions/targetResult"
        },
        "unit": {
          "$ref": "#/definitions/targetResult"
        },
        "all_tests": {
          "$ref": "#/definitions/targetResult"
        }
      },
      "additionalProperties": false
    },
    "orchestration": {
      "type": "object",
      "required": [
        "pre",
        "post"
      ],
      "properties": {
        "pre": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/orchestrationStep"
          }
        },
        "post": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/orchestrationStep"
          }
        }
      },
      "additionalProperties": false
    },
    "tactics_used": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "attempts": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/attempt"
      }
    },
    "evidence": {
      "type": "object",
      "required": [
        "log_refs",
        "diagnostics"
      ],
      "properties": {
        "log_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "diagnostics": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": false
    },
    "repro_check": {
      "type": "object",
      "required": [
        "status",
        "details"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "passed",
            "failed"
          ]
        },
        "details": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "prompt_delta_suggestion": {
      "type": "object",
      "required": [
        "status",
        "summary",
        "candidate_lines"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "none",
            "proposed"
          ]
        },
        "summary": {
          "type": "string"
        },
        "candidate_lines": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    }
  },
  "definitions": {
    "targetStatus": {
      "type": "string",
      "enum": [
        "passed",
        "failed",
        "not_attempted"
      ]
    },
    "failureCode": {
      "$comment": "Use infra_support when targets.active=unsupported and build cannot be made runnable in this healing attempt.",
      "type": "string",
      "enum": [
        "tool_not_detected",
        "runtime_version_mismatch",
        "docker_api_mismatch",
        "registry_auth_failed",
        "registry_ca_trust_failed",
        "external_service_unreachable",
        "command_not_found",
        "timeout",
        "infra_support",
        "unknown"
      ]
    },
    "targetResult": {
      "$comment": "Infra-healing should always materialize command/env for the selected targets.active entry, even when missing in input context.",
      "type": "object",
      "required": [
        "status",
        "env"
      ],
      "properties": {
        "status": {
          "$ref": "#/definitions/targetStatus"
        },
        "command": {
          "type": "string"
        },
        "env": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "failure_code": {
          "oneOf": [
            {
              "$ref": "#/definitions/failureCode"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "status": {
                "const": "passed"
              }
            }
          },
          "then": {
            "required": [
              "command"
            ],
            "properties": {
              "failure_code": {
                "type": "null"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "status": {
                "const": "failed"
              }
            }
          },
          "then": {
            "required": [
              "command",
              "failure_code"
            ],
            "properties": {
              "failure_code": {
                "$ref": "#/definitions/failureCode"
              }
            }
          }
        }
      ]
    },
    "stack": {
      "type": "object",
      "required": [
        "language",
        "tool"
      ],
      "properties": {
        "language": {
          "type": "string",
          "minLength": 1
        },
        "tool": {
          "type": "string",
          "minLength": 1
        },
        "release": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "runtimeHints": {
      "type": "object",
      "properties": {
        "docker": {
          "$ref": "#/definitions/runtimeDocker"
        }
      },
      "additionalProperties": false
    },
    "runtimeDocker": {
      "type": "object",
      "required": [
        "mode"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "none",
            "host_socket",
            "tcp"
          ]
        },
        "host": {
          "type": "string",
          "minLength": 1
        },
        "api_version": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false,
      "oneOf": [
        {
          "properties": {
            "mode": {
              "const": "none"
            }
          },
          "required": [
            "mode"
          ]
        },
        {
          "properties": {
            "mode": {
              "const": "host_socket"
            }
          },
          "required": [
            "mode"
          ]
        },
        {
          "properties": {
            "mode": {
              "const": "tcp"
            },
            "host": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": [
            "mode",
            "host"
          ]
        }
      ]
    },
    "orchestrationStep": {
      "type": "object",
      "required": [
        "id",
        "type",
        "args"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": [
            "docker_network",
            "docker_network_remove",
            "docker_container",
            "docker_remove",
            "wait_for_log",
            "health_check"
          ]
        },
        "args": {
          "type": "object"
        }
      },
      "additionalProperties": false
    },
    "attempt": {
      "type": "object",
      "required": [
        "target",
        "command",
        "env",
        "exit_code",
        "reason"
      ],
      "properties": {
        "target": {
          "type": "string",
          "enum": [
            "build",
            "unit",
            "all_tests"
          ]
        },
        "command": {
          "type": "string",
          "minLength": 1
        },
        "env": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "exit_code": {
          "type": "integer"
        },
        "reason": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "runner_mode": {
            "const": "simple"
          }
        }
      },
      "then": {
        "properties": {
          "orchestration": {
            "type": "object",
            "properties": {
              "pre": {
                "maxItems": 0
              },
              "post": {
                "maxItems": 0
              }
            }
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
