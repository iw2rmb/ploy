#!/usr/bin/env bash
# Pre-commit hook: enforce Go formatting/imports.
# - Runs goimports (if available) and gofmt -s on all tracked .go files
# - Re-stages formatted files to keep commit atomic
# - Keeps output terse

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

# Populate GOFILES without relying on Bash 4+ 'mapfile'.
# Works on macOS' Bash 3.2 by reading NUL-delimited paths.
GOFILES=()
while IFS= read -r -d '' _f; do
  GOFILES+=("$_f")
done < <(git ls-files -z '*.go')

if ((${#GOFILES[@]}==0)); then
  exit 0
fi

if command -v goimports >/dev/null 2>&1; then
  printf '[pre-commit] goimports formatting…\n'
  goimports -w "${GOFILES[@]}"
else
  printf '[pre-commit] goimports not found; skipping import grouping.\n' >&2
fi

printf '[pre-commit] gofmt -s formatting…\n'
gofmt -s -w "${GOFILES[@]}"

# Re-stage updated files
git add -- "${GOFILES[@]}"

printf '[pre-commit] formatting complete.\n'
