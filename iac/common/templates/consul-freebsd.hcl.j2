datacenter = "dc1"
data_dir = "/var/db/consul"
log_level = "INFO"
node_name = "consul-freebsd-{{ ansible_hostname }}"
server = false

# FreeBSD-specific configuration
# Bind to the primary network interface
bind_addr = "{{ ansible_default_ipv4.address | default('127.0.0.1') }}"
client_addr = "0.0.0.0"
advertise_addr = "{{ ansible_default_ipv4.address | default('127.0.0.1') }}"

ports {
  grpc = 8502
}

connect {
  enabled = true
}

ui_config {
  enabled = false
}

acl = {
  enabled = false
  default_policy = "allow"
}

# Performance configurations for FreeBSD
performance {
  raft_multiplier = 1
}

# Join the Linux consul server
retry_join = ["{{ hostvars[groups['linux_hosts'][0]]['ansible_default_ipv4']['address'] }}"]

# FreeBSD-specific logging
log_file = "/var/log/consul/"
log_rotate_duration = "24h"
log_rotate_max_files = 7

# FreeBSD service integration
enable_syslog = true
syslog_facility = "LOCAL0"