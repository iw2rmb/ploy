FROM gradle:8-jdk{{ .JavaVersion }} AS build
WORKDIR /src
COPY . .
# Inject a Gradle init script to enforce Java release and disable tests (no repo edits)
RUN set -eux; \
  cat > /tmp/ploy-init.gradle <<'EOF'; \
import org.gradle.api.tasks.compile.JavaCompile;\n
allprojects {\n  // Disable tests to speed up container builds\n  tasks.withType(Test).configureEach { enabled = false }\n  // Ensure JavaCompile releases target the requested Java level\n  tasks.withType(JavaCompile).configureEach {\n    try {\n      options.release = {{ .JavaVersion }}\n    } catch (Throwable ignored) {\n      try { options.release.set({{ .JavaVersion }}) } catch (Throwable ignored2) { }\n    }\n  }\n  // Set toolchain when java plugin is present\n  plugins.withId('java') {\n    try {\n      java { toolchain { languageVersion = JavaLanguageVersion.of({{ .JavaVersion }}) } }\n    } catch (Throwable ignored) { }\n  }\n}\nEOF\n; \
  chmod +x ./gradlew || true; \
  ( ./gradlew -I /tmp/ploy-init.gradle -x test clean build --stacktrace --info \\
      -Dorg.gradle.java.installations.auto-detect=true \\
      -Dorg.gradle.java.installations.auto-download=true \
    || gradle -I /tmp/ploy-init.gradle -x test clean build --stacktrace --info \\
      -Dorg.gradle.java.installations.auto-detect=true \\
      -Dorg.gradle.java.installations.auto-download=true ); \
  # Robust JAR selection: prefer boot/shadow JARs; otherwise select the largest JAR
  SEL=""; \
  mapfile -t CANDS < <(find . -path '*/build/libs/*.jar' -type f 2>/dev/null || true); \
  if [ ${#CANDS[@]} -eq 0 ]; then echo "No JARs produced"; exit 1; fi; \
  for j in "${CANDS[@]}"; do \
    if echo "$j" | grep -Ei '(boot|shadow).*\.jar$' >/dev/null; then SEL="$j"; break; fi; \
  done; \
  if [ -z "$SEL" ]; then \
    # pick largest by size
    SEL=$(printf '%s\n' "${CANDS[@]}" | xargs -I{} stat -c '%s %n' {} | sort -nr | awk 'NR==1{ $1=""; sub(/^ /,""); print }'); \
  fi; \
  test -n "$SEL" && { mkdir -p /src/build/libs; cp "$SEL" /src/build/libs/app.jar; } || { echo "Failed to select JAR"; exit 1; }

FROM eclipse-temurin:{{ .JavaVersion }}-jre
WORKDIR /app
COPY --from=build /src/build/libs/*.jar /app/app.jar
ENV PORT=8080
EXPOSE 8080
{{- if .MainClass }}
ENTRYPOINT ["java","-cp","/app/app.jar","{{ .MainClass }}"]
{{- else }}
ENTRYPOINT ["java","-jar","/app/app.jar"]
{{- end }}
