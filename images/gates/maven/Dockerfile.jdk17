ARG JAVA_BASE_MAVEN_17_IMAGE=java-base-maven:jdk17
FROM ${JAVA_BASE_MAVEN_17_IMAGE}

LABEL org.opencontainers.image.title="ploy-gate-maven-jdk17" \
    org.opencontainers.image.description="Ploy Maven gate runner image with Maven 3 and Eclipse Temurin JDK 17" \
    org.opencontainers.image.source="https://github.com/iw2rmb/ploy" \
    org.opencontainers.image.licenses="MIT"

ENV MAVEN_CONFIG=/root/.m2
