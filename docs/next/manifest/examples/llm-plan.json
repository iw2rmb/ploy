{
  "schema_version": "v1",
  "id": "llm-plan",
  "name": "LLM Planner",
  "step_ref": "llm-plan",
  "inputs": {
    "repo": {
      "url": "https://gitlab.com/acme/repo.git",
      "base_ref": "main",
      "target_ref": "feature/x"
    },
    "diffs": [],
    "data": []
  },
  "runtime": {
  "image": "registry.dev/ploy/mods-llm:latest",
  "command": ["mods-llm"],
  "args": ["--plan", "--input", "/workspace", "--out", "/out/plan.json"],
  "env": { "OPENAI_API_KEY": "${OPENAI_API_KEY}" },
    "resources": { "cpu": "1", "memory": "1Gi", "disk": "2Gi" }
  },
  "outputs": {
    "plan": { "path": "/out/plan.json", "media_type": "application/json" },
    "data": [ { "name": "planner-log", "path": "/out/planner.log", "media_type": "text/plain" } ]
  },
  "retention": { "retain_container": false, "ttl": "72h" }
}
