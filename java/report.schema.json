{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ploy.local/java/report.schema.json",
  "title": "Java Dependency Impact Report",
  "type": "object",
  "additionalProperties": false,
  "$comment": "Top-level consolidated report for dependency upgrade impact on currently used symbols.",
  "required": ["target", "inputs", "updates", "removals", "warnings"],
  "properties": {
    "target": {
      "type": "object",
      "additionalProperties": false,
      "$comment": "Resolved upgrade target and version interval used for analysis.",
      "required": ["request", "ga", "from", "to"],
      "properties": {
        "request": {
          "type": "string",
          "$comment": "Original --target input value."
        },
        "ga": {
          "type": "string",
          "pattern": "^[^:@]+:[^:@]+$",
          "$comment": "Target dependency group/artifact without version."
        },
        "from": {
          "type": "string",
          "$comment": "Old version used for managed-dependency diff."
        },
        "to": {
          "type": "string",
          "$comment": "New desired version used for managed-dependency diff."
        }
      }
    },
    "inputs": {
      "type": "object",
      "additionalProperties": false,
      "$comment": "Execution inputs used by the report builder.",
      "required": ["repo", "classpath_file"],
      "properties": {
        "repo": {
          "type": "string",
          "$comment": "Absolute repository path scanned for source usage and build files."
        },
        "classpath_file": {
          "type": "string",
          "$comment": "Absolute path to newline-delimited .classpath file."
        }
      }
    },
    "updates": {
      "type": "array",
      "$comment": "Dependencies that changed version and have used, non-added incompatible changes.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["ga", "changes"],
        "properties": {
          "ga": {
            "type": "string",
            "pattern": "^[^:@]+:[^:@]+@.+\\.\\.\\..+$",
            "$comment": "Dependency coordinate in group:artifact@from...to form."
          },
          "changes": {
            "type": "array",
            "$comment": "Used incompatible changes; *_ADDED changes are intentionally excluded.",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["kind", "class", "member", "type", "javadoc"],
              "properties": {
                "kind": {
                  "type": "string",
                  "enum": [
                    "class",
                    "field",
                    "constructor",
                    "method",
                    "interface",
                    "superclass",
                    "unknown"
                  ],
                  "$comment": "Source entity category from japicmp-to-report mapping."
                },
                "class": {
                  "type": "string",
                  "$comment": "Fully qualified owner class name for the change."
                },
                "member": {
                  "type": ["string", "null"],
                  "$comment": "Member signature or name when applicable; null for class-level changes."
                },
                "type": {
                  "type": "string",
                  "$comment": "Raw japicmp compatibility change type."
                },
                "javadoc": {
                  "type": "object",
                  "additionalProperties": false,
                  "$comment": "Last known deprecation note metadata for removal-like symbols when available.",
                  "required": ["note", "version"],
                  "properties": {
                    "note": {
                      "type": ["string", "null"],
                      "$comment": "Deprecated note text found in historical sources jar."
                    },
                    "version": {
                      "type": ["string", "null"],
                      "$comment": "Version where deprecated note was found."
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "removals": {
      "type": "array",
      "$comment": "Managed dependencies removed by the target upgrade and currently used in code.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["ga", "usage"],
        "properties": {
          "ga": {
            "type": "string",
            "pattern": "^[^:@]+:[^:@]+@.+$",
            "$comment": "Removed dependency coordinate in group:artifact@oldVersion form."
          },
          "usage": {
            "type": "array",
            "$comment": "Resolved symbols currently used from the removed dependency.",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "warnings": {
      "type": "array",
      "$comment": "Known limitations and analysis warnings emitted during report generation.",
      "items": {
        "type": "string"
      }
    }
  }
}
