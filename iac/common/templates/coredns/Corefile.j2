# CoreDNS configuration generated by Ansible
{{ coredns.zone }}:{{ coredns.port | default(1053) }} {
    log
    errors
    health :{{ coredns.health_port | default(8088) }} {
        lameduck 5s
    }
    ready :{{ coredns.ready_port | default(8181) }}
    prometheus :9153
    reload
    cache {{ coredns.cache_ttl | default(120) }}
    file /etc/coredns/zones/{{ coredns.zone }}.db
    forward . {{ (coredns.upstream | default(['1.1.1.1', '8.8.8.8'])) | join(' ') }}
}
