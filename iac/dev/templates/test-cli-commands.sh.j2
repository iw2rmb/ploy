#!/bin/bash
# Test script for new CLI commands: domains, certs, debug, rollback

set -e

echo "=== Testing New CLI Commands ==="

# Set up environment
export PLOY_CONTROLLER="http://localhost:8081/v1"
cd /home/ploy/ploy

# Build CLI if not exists
if [ ! -f "./ploy" ]; then
    echo "Building Ploy CLI..."
    go build -o ploy ./cmd/ploy
fi

# Test app for CLI commands
TEST_APP="test-cli-app"
TEST_DOMAIN="example.com"
TEST_SHA="abc123def456"

echo
echo "--- Testing domains commands ---"

# Test domains add
echo "Testing: ploy domains add $TEST_APP $TEST_DOMAIN"
./ploy domains add $TEST_APP $TEST_DOMAIN
if [ $? -eq 0 ]; then
    echo "✓ domains add command executed successfully"
else
    echo "✗ domains add command failed"
    exit 1
fi

# Test domains list
echo "Testing: ploy domains list $TEST_APP"
./ploy domains list $TEST_APP
if [ $? -eq 0 ]; then
    echo "✓ domains list command executed successfully"
else
    echo "✗ domains list command failed"
    exit 1
fi

# Test domains remove
echo "Testing: ploy domains remove $TEST_APP $TEST_DOMAIN"
./ploy domains remove $TEST_APP $TEST_DOMAIN
if [ $? -eq 0 ]; then
    echo "✓ domains remove command executed successfully"
else
    echo "✗ domains remove command failed"
    exit 1
fi

echo
echo "--- Testing certs commands ---"

# Test certs issue
echo "Testing: ploy certs issue $TEST_DOMAIN"
./ploy certs issue $TEST_DOMAIN
if [ $? -eq 0 ]; then
    echo "✓ certs issue command executed successfully"
else
    echo "✗ certs issue command failed"
    exit 1
fi

# Test certs list
echo "Testing: ploy certs list"
./ploy certs list
if [ $? -eq 0 ]; then
    echo "✓ certs list command executed successfully"
else
    echo "✗ certs list command failed"
    exit 1
fi

echo
echo "--- Testing debug commands ---"

# Test debug shell
echo "Testing: ploy debug shell $TEST_APP"
./ploy debug shell $TEST_APP
if [ $? -eq 0 ]; then
    echo "✓ debug shell command executed successfully"
else
    echo "✗ debug shell command failed"
    exit 1
fi

# Test debug shell with lane
echo "Testing: ploy debug shell $TEST_APP --lane A"
./ploy debug shell $TEST_APP --lane A
if [ $? -eq 0 ]; then
    echo "✓ debug shell with lane command executed successfully"
else
    echo "✗ debug shell with lane command failed"
    exit 1
fi

echo
echo "--- Testing rollback commands ---"

# Test rollback
echo "Testing: ploy rollback $TEST_APP $TEST_SHA"
./ploy rollback $TEST_APP $TEST_SHA
if [ $? -eq 0 ]; then
    echo "✓ rollback command executed successfully"
else
    echo "✗ rollback command failed"
    exit 1
fi

echo
echo "--- Testing CLI help and usage ---"

# Test main usage
echo "Testing: ploy (no args - should show TUI or usage)"
timeout 2 ./ploy || echo "✓ ploy main command handled correctly"

# Test individual command help
echo "Testing command help messages..."

./ploy domains 2>&1 | grep -q "usage:" && echo "✓ domains help message works"
./ploy certs 2>&1 | grep -q "usage:" && echo "✓ certs help message works" 
./ploy debug 2>&1 | grep -q "usage:" && echo "✓ debug help message works"
./ploy rollback 2>&1 | grep -q "usage:" && echo "✓ rollback help message works"

echo
echo "--- Testing error handling ---"

# Test invalid commands
echo "Testing error handling for invalid arguments..."

./ploy domains invalid 2>/dev/null && echo "✗ Should reject invalid domains command" || echo "✓ Correctly rejects invalid domains command"
./ploy certs invalid 2>/dev/null && echo "✗ Should reject invalid certs command" || echo "✓ Correctly rejects invalid certs command"
./ploy debug invalid 2>/dev/null && echo "✗ Should reject invalid debug command" || echo "✓ Correctly rejects invalid debug command"

# Test missing arguments
./ploy domains add 2>/dev/null && echo "✗ Should require app and domain" || echo "✓ Correctly requires arguments for domains add"
./ploy rollback $TEST_APP 2>/dev/null && echo "✗ Should require SHA" || echo "✓ Correctly requires SHA for rollback"

echo
echo "=== CLI Commands Test Complete ==="
echo "All new CLI commands (domains, certs, debug, rollback) are working correctly!"