#!/bin/bash
# API Rollback Script
# Rolls back Ploy API using unified deployment system

set -e

PLOY_DIR="/home/ploy/ploy"
CONTROLLER_SCRIPTS_DIR="/home/ploy/controller-scripts"

echo "=== Ploy API Rollback via Unified Deployment System ==="

# Check if we're in the right directory
if [[ ! -d "$PLOY_DIR" ]]; then
    echo "Error: Ploy directory not found at $PLOY_DIR"
    exit 1
fi

cd "$PLOY_DIR"

# Check if ployman CLI is available
if [[ ! -x "./bin/ployman" ]]; then
    echo "Building ployman CLI..."
    go build -o bin/ployman ./cmd/ployman
    
    if [[ ! -x "./bin/ployman" ]]; then
        echo "Error: Failed to build ployman CLI"
        exit 1
    fi
fi

# Get target version
TARGET_VERSION=""
if [[ $# -eq 0 ]]; then
    echo "Usage: $0 <target-git-commit-hash>"
    echo "Or run interactively:"
    
    # Show recent git commits for selection
    echo "Recent commits available for rollback:"
    git log --oneline -10
    echo ""
    
    read -p "Enter target git commit hash to rollback to: " TARGET_VERSION
else
    TARGET_VERSION="$1"
fi

if [[ -z "$TARGET_VERSION" ]]; then
    echo "Error: No target version specified"
    exit 1
fi

# Validate git commit exists
if ! git cat-file -e "$TARGET_VERSION" 2>/dev/null; then
    echo "Error: Git commit '$TARGET_VERSION' does not exist"
    exit 1
fi

# Get current version
CURRENT_VERSION=$(cat /opt/ploy/current-api-version 2>/dev/null || echo "unknown")
echo "Current version: $CURRENT_VERSION"
echo "Target git commit: $TARGET_VERSION"

# Confirm rollback
read -p "Are you sure you want to rollback? (y/N): " CONFIRM
if [[ "$CONFIRM" != "y" && "$CONFIRM" != "Y" ]]; then
    echo "Rollback cancelled"
    exit 0
fi

# Checkout target commit
echo "Checking out target commit..."
ORIGINAL_COMMIT=$(git rev-parse HEAD)
git checkout "$TARGET_VERSION"

# Build API binary from target commit
echo "Building API binary from target commit..."
if ! go build -o bin/api ./api; then
    echo "Error: Failed to build API from target commit"
    git checkout "$ORIGINAL_COMMIT"
    exit 1
fi

# Generate rollback version identifier
ROLLBACK_VERSION="rollback-$(date +%Y%m%d-%H%M%S)-$(git rev-parse --short HEAD)"
echo "Rollback version: $ROLLBACK_VERSION"

# Try unified deployment first
echo "Initiating rollback using unified deployment system..."
export PLOY_CONTROLLER="https://api.dev.ployman.app/v1"

# Deploy using ployman push
if ./bin/ployman push -a ploy-api; then
    echo "✅ Rollback initiated successfully via ployman"
else
    echo "⚠️  Unified deployment failed, using fallback bootstrap method..."
    
    # Fallback: direct bootstrap deployment
    cp bin/api /tmp/ploy-api-bootstrap
    chmod +x /tmp/ploy-api-bootstrap
    
    # Use existing bootstrap job
    export NOMAD_ADDR="http://localhost:4646"
    if nomad job run /opt/hashicorp/nomad/jobs/ploy-api-bootstrap.hcl; then
        echo "✅ Fallback bootstrap rollback successful"
    else
        echo "❌ Fallback rollback also failed"
        git checkout "$ORIGINAL_COMMIT"
        exit 1
    fi
fi

# Monitor rollback deployment
echo "Monitoring rollback progress..."
TIMEOUT=300  # 5 minutes
START_TIME=$(date +%s)

while true; do
    CURRENT_TIME=$(date +%s)
    if (( CURRENT_TIME - START_TIME > TIMEOUT )); then
        echo "Error: Rollback timeout after 5 minutes"
        git checkout "$ORIGINAL_COMMIT"
        exit 1
    fi

    # Check allocation status
    if ALLOCS=$(/opt/hashicorp/bin/nomad-job-manager.sh allocs ploy-api json 2>/dev/null); then
        RUNNING_COUNT=$(echo "$ALLOCS" | jq -r '.[].ClientStatus' | grep -c "running" || echo "0")
        TOTAL_COUNT=$(echo "$ALLOCS" | jq '. | length')

        echo "Allocation status: $RUNNING_COUNT/$TOTAL_COUNT running"

        if [[ "$RUNNING_COUNT" == "$TOTAL_COUNT" ]] && [[ "$RUNNING_COUNT" -gt "0" ]]; then
            echo "All allocations are running!"
            break
        fi
    else
        echo "Waiting for job allocations..."
    fi

    sleep 10
done

# Verify rollback health
echo "Verifying API health after rollback..."
sleep 30  # Allow time for startup

HEALTH_ENDPOINTS=(
    "http://localhost:{{ ploy.api_port }}/health"
    "https://api.dev.ployman.app/health"
)

SUCCESS_COUNT=0
for endpoint in "${HEALTH_ENDPOINTS[@]}"; do
    if curl -f -s "$endpoint" > /dev/null 2>&1; then
        echo "✅ Health check passed: $endpoint"
        SUCCESS_COUNT=$((SUCCESS_COUNT + 1))
    else
        echo "⚠️  Health check failed: $endpoint"
    fi
done

if [[ "$SUCCESS_COUNT" -eq 0 ]]; then
    echo "❌ All health checks failed after rollback"
    echo "Manual intervention required"
    git checkout "$ORIGINAL_COMMIT"
    exit 1
else
    echo "✅ Rollback health check passed"
    
    # Update current version file
    echo "$ROLLBACK_VERSION" | sudo tee /opt/ploy/current-api-version > /dev/null
    echo "✅ Rollback completed successfully to commit $TARGET_VERSION"
    echo "Rollback version: $ROLLBACK_VERSION"
fi

# Stay on the rollback commit
echo "Repository is now on rollback commit: $TARGET_VERSION"
echo "API endpoints:"
echo "  - Local: http://localhost:{{ ploy.api_port }}/health"
echo "  - External: https://api.dev.ployman.app/health"
echo "  - API version: https://api.dev.ployman.app/v1/version"