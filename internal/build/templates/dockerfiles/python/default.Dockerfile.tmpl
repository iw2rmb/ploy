FROM python:{{ .PythonVersion }}-slim
WORKDIR /app
ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1
ENV PYTHONPATH=/app
ENV PORT=8080
COPY . .
RUN if [ -f requirements.txt ] && [ -s requirements.txt ]; then pip install --no-cache-dir -r requirements.txt; fi || true
EXPOSE 8080
{{- if .UseGunicorn }}
CMD ["sh","-lc","exec gunicorn -b 0.0.0.0:$PORT app:app"]
{{- else if .UseUvicorn }}
CMD ["sh","-lc","exec uvicorn app:app --host 0.0.0.0 --port $PORT"]
{{- else }}
CMD ["python","app.py"]
{{- end }}

