{
  "schema_version": "v1",
  "id": "llm-exec",
  "name": "LLM Executor",
  "step_ref": "llm-exec",
  "inputs": {
    "repo": {
      "url": "https://gitlab.com/acme/repo.git",
      "base_ref": "main",
      "target_ref": "feature/x"
    },
    "diffs": [
      { "cid": "bafybasecid...", "digest": "sha256:base...", "message": "baseline before llm-exec" }
    ],
    "data": [
      { "name": "plan", "cid": "bafyplan...", "media_type": "application/json" }
    ]
  },
  "runtime": {
  "image": "registry.<cluster-id>.ploy/ploy/mods-llm:latest",
  "command": ["mods-llm"],
  "args": ["--execute", "--workspace", "/workspace", "--plan", "/in/plan.json", "--out", "/out"],
    "env": {},
    "resources": { "cpu": "2", "memory": "2Gi", "disk": "4Gi" }
  },
  "outputs": {
    "diff": { "target": "/workspace" },
    "data": [ { "name": "exec-log", "path": "/out/exec.log", "media_type": "text/plain" } ]
  },
  "retention": { "retain_container": false, "ttl": "72h" }
}
