{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/mods/next.schema.json",
  "title": "Next Action",
  "type": "object",
  "required": ["action"],
  "properties": {
    "action": { "enum": ["stop", "new_plan"] },
    "plan": {
      "type": "object",
      "required": ["plan_id", "options"],
      "properties": {
        "plan_id": { "type": "string" },
        "options": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["id", "type"],
            "properties": {
              "id": { "type": "string" },
              "type": { "enum": ["human", "llm-exec", "orw-gen"] },
              "inputs": { "type": "object", "additionalProperties": true },
              "success_criteria": { "type": "string" },
              "max_duration": { "type": "string" }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
