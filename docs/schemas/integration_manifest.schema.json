{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Ploy Integration Manifest",
  "description": "Schema for defining Ploy integration manifests consumed by the workstation CLI.",
  "type": "object",
  "required": [
    "manifest_version",
    "name",
    "version",
    "summary",
    "topology",
    "fixtures",
    "lanes",
    "services",
    "edges"
  ],
  "properties": {
    "manifest_version": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "topology": {
      "type": "object"
    },
    "fixtures": {
      "type": "object",
      "required": [
        "required"
      ],
      "properties": {
        "required": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "optional": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "lanes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "services": {
      "type": "object",
      "additionalProperties": {
        "type": "object"
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "exposures": {
      "type": "object",
      "additionalProperties": {
        "type": "object"
      }
    }
  },
  "additionalProperties": false
}
