datacenter = "dc1"
data_dir = "/opt/hashicorp/nomad"
log_level = "INFO"
name = "ploy-dev-node"

# Network configuration - Bind to localhost, advertise localhost for development
bind_addr = "127.0.0.1"
advertise {
  http = "127.0.0.1"
  rpc = "127.0.0.1"
  serf = "127.0.0.1"
}

# Enable metrics for monitoring
telemetry {
  prometheus_metrics = true
  publish_allocation_metrics = true
  publish_node_metrics = true
}

server {
  enabled = true
  bootstrap_expect = 1
  
  # Enhanced server configuration for Ploy
  default_scheduler_config {
    scheduler_algorithm = "spread"
    preemption_config {
      batch_scheduler_enabled = true
      system_scheduler_enabled = true
      service_scheduler_enabled = false
    }
  }
}

client {
  enabled = true
  servers = ["127.0.0.1:4647"]
  
  # Placement metadata for gateway/edge nodes (used by Traefik placement)
  meta {
    {{ ploy_gateway_node_meta_key | default('role') }} = "{{ ploy_gateway_node_class | default('gateway') }}"
  }
  
  # Enhanced client configuration for Ploy lanes
  options {
    "driver.raw_exec.enable" = "1"
    "driver.exec.enable" = "1"
    "driver.java.enable" = "1"
  }
  
  # Resource configuration
  reserved {
    cpu = 100
    memory = 256
    disk = 1024
  }
  
  # Host volumes for persistent storage
  host_volume "artifacts" {
    path      = "/opt/ploy/artifacts"
    read_only = false
  }
  
  host_volume "ploy-logs" {
    path      = "/opt/ploy/logs"
    read_only = false
  }

  # Host volumes for Mods planner/LLM/ORW jobs (optional if using docker bind mounts)
  host_volume "mods-context" {
    path      = "/opt/ploy/mods/context"
    read_only = false
  }
  host_volume "mods-out" {
    path      = "/opt/ploy/mods/out"
    read_only = false
  }
}

consul {
  address = "127.0.0.1:8500"
  auto_advertise = true
  server_auto_join = true
  client_auto_join = true
}

vault {
  enabled = false
  address = "http://127.0.0.1:8200"
}

plugin "docker" {
  config {
    allow_privileged = true
    
    # Allow Kontain runtime
    allow_runtimes = ["runc", "io.kontain"]
    
    # Additional Docker configuration
    volumes {
      enabled = true
    }
  }
}

plugin "qemu" {
  config {
    # Enable QEMU driver for unikernel and VM workloads
    image_paths = ["/opt/ploy/artifacts", "/tmp"]
  }
}

ui {
  enabled = true
}

ports {
  http = 4646
  rpc = 4647
  serf = 4648
}

# Listen on all interfaces for local development access
addresses {
  http = "0.0.0.0"
  rpc = "0.0.0.0"
  serf = "0.0.0.0"
}

# Rate limiting configuration to prevent 429 errors
limits {
  # HTTP API connection caps (raise to avoid 429 on /v1/* under load)
  http_max_conns            = 10000
  http_max_conns_per_client = 512

  # RPC limits (keep generous defaults for single node dev)
  rpc_max_conns             = 10000
  rpc_max_conns_per_client  = 512

  # Handshake timeouts
  https_handshake_timeout   = "10s"
  rpc_handshake_timeout     = "10s"
}
