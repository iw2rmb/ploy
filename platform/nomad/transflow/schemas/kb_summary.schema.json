{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/transflow/kb_summary.schema.json",
  "title": "KB Error Summary",
  "type": "object",
  "required": ["language", "signature", "promoted", "stats"],
  "properties": {
    "language": { "type": "string" },
    "signature": { "type": "string" },
    "promoted": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["kind", "ref", "score"],
        "properties": {
          "kind": { "enum": ["orw_recipe", "patch_fingerprint"] },
          "ref": { "type": "string" },
          "score": { "type": "number" },
          "wins": { "type": "integer", "minimum": 0 },
          "failures": { "type": "integer", "minimum": 0 },
          "last_success_at": { "type": "string", "format": "date-time" }
        },
        "additionalProperties": false
      }
    },
    "stats": {
      "type": "object",
      "properties": {
        "cases": { "type": "integer", "minimum": 0 },
        "recent_window": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
