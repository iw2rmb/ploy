FROM docker-hosted.artifactory.tcsbank.ru/sec-base-images/ubuntu-noble-java-adoptium-25-cicd:latest

LABEL org.opencontainers.image.title="java-base-temurin-jdk25" \
    org.opencontainers.image.description="Ploy Java base lane: Temurin JDK 25 on ubuntu-noble-java-adoptium-25-cicd"

RUN apt-get update \
    && DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
    bash git jq \
    && rm -rf /var/lib/apt/lists/*

ENV LANG=C.UTF-8 \
    LC_ALL=C.UTF-8
